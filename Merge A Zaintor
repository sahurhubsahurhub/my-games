    ${upgCard('#60a5fa','⚡','Fuse Speed',gs.fuseSpeed,`Animation <b style="color:#60a5fa;">×${sm.toFixed(2)}</b> speed<br>Cost ×1.80/level`,sc,'buySpeed')}
