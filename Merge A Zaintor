// ═══════════════════════════════ GAME ACTIONS ═════════════════════════════════
function selFuse(id){gs.selectedFuse=id;renderAll();}
function toggleAuto(){gs.autoFuse=!gs.autoFuse;saveGS();renderAll();}

function buyLuck(){
  const cost=luckCost();if(gs.charges<cost){notif(`Need ${fmt(cost)}⚡`,'#ef4444');return;}
  gs.charges-=cost;gs.stats.chSpent=(gs.stats.chSpent||0)+cost;gs.luckLevel++;saveGS();
  notif(`🍀 Luck → Lv.${gs.luckLevel} (eff. ${effectiveLuck().toFixed(1)})`, '#fbbf24');renderAll();
}
function buySpeed(){
  const cost=speedCost();if(gs.charges<cost){notif(`Need ${fmt(cost)}⚡`,'#ef4444');return;}
  gs.charges-=cost;gs.stats.chSpent=(gs.stats.chSpent||0)+cost;gs.fuseSpeed++;saveGS();
  notif(`⚡ Fuse Speed → Lv.${gs.fuseSpeed} (×${animSpeedMult().toFixed(2)})`, '#60a5fa');renderAll();
}
function buySlot(){
  const cost=slotCost();if(gs.charges<cost){notif(`Need ${fmt(cost)}⚡`,'#ef4444');return;}
  if(gs.maxSlots>=12){notif('Max slots!','#ef4444');return;}
  gs.charges-=cost;gs.stats.chSpent=(gs.stats.chSpent||0)+cost;
  gs.maxSlots++;gs.equipped.push(null);saveGS();
  notif(`Slot ${gs.maxSlots} unlocked!`,'#60a5fa');renderAll();
}
function buyPShop(id){
  const item=PSHOP.find(x=>x.id===id);if(!item)return;
  const owned=gs.pShop[id]||0;
  if(owned>=item.max){notif('Already maxed!','#22c55e');return;}
  if(gs.prestigeTokens<item.cost){notif(`Need ${item.cost}🪙`,'#ef4444');return;}
  gs.prestigeTokens-=item.cost;gs.pShop[id]=(gs.pShop[id]||0)+1;saveGS();
  notif(`${item.name} purchased!`,'#fbbf24');renderAll();
}
function equipFromInv(fusionId,tier){
  const slot=gs.equipped.findIndex(e=>e===null);
  if(slot===-1){notif('All slots full!','#ef4444');return;}
  if(!removeFromInv(fusionId,tier)){notif('Not found in inventory','#ef4444');return;}
  gs.equipped[slot]={fusionId,tier};saveGS();
  const f=getFusion(fusionId);notif(`${f?.name} equipped!`,tierColor(tier)||f?.color||'#22c55e');renderAll();
}
function unequipSlot(i){
  const e=gs.equipped[i];if(!e)return;
  gs.equipped[i]=null;addToInv(e.fusionId,e.tier);saveGS();
  const f=getFusion(e.fusionId);notif(`${f?.name} unequipped`,'#6b7280');renderAll();
}
function sellFusion(fusionId,tier){
  if(!removeFromInv(fusionId,tier)){notif('Not in inventory','#ef4444');return;}
  const v=sellValue(fusionId,tier);gs.charges+=v;gs.stats.chargesEarned=(gs.stats.chargesEarned||0)+v;
  gs.stats.sellCt=(gs.stats.sellCt||0)+1;saveGS();
  notif(`Sold for +${fmt(v)}⚡`,'#f87171');renderAll();
}
function combineFusion(fusionId,tier){
  const stack=getStack(fusionId,tier);
  if(!stack||stack.count<2){notif('Need 2 to combine!','#ef4444');return;}
  const nt=nextTier(tier);if(!nt){notif('Already max tier!','#fbbf24');return;}
  removeFromInv(fusionId,tier,2);addToInv(fusionId,nt);
  gs.stats.combineCt=(gs.stats.combineCt||0)+1;saveGS();
  const f=getFusion(fusionId);const tc=tierColor(nt);
  notif(`${f?.name} → ${TIERS[nt].label}!`,tc||f?.color||'#fbbf24');renderAll();
}
function doPrestige(){
  const cost=prestigeCost(),cm=chargeMult(),sm=Math.pow(1.2,gs.prestigeLevel);
  if(gs.charges<cost){notif(`Need ${fmt(cost)}⚡`,'#ef4444');return;}
  const next=gs.prestigeLevel+1;
  if(!confirm(`Prestige ${next}?\n\nRESETS: charges, Luck Lv.${gs.luckLevel}, Speed Lv.${gs.fuseSpeed}, bought slots (fusions return to inventory)\nKEEPS: inventory, equipped fusions, prestige shop items\n\nGAINS PERMANENTLY:\n• Charge mult: ×${(cm*1.3).toFixed(2)}\n• +2 luck levels (total +${next*2})\n• Speed: ×${(sm*1.2).toFixed(2)}\n• +2 prestige tokens\n\nContinue?`))return;
  // Return extra-slot fusions to inventory
  const keep=gs.equipped.slice(0,6);
  for(const e of gs.equipped.slice(6)){if(e)addToInv(e.fusionId,e.tier);}
  const inv=gs.inventory,pShop=gs.pShop,stats=gs.stats,prevTokens=gs.prestigeTokens;
  gs=defState();
  gs.inventory=inv;gs.equipped=keep;gs.pShop=pShop;gs.stats=stats;
  gs.prestigeLevel=next;gs.prestigeTokens=prevTokens+2;
  gs.selectedFuse='basic';
  saveGS();notif(`✦ Prestige ${next}! +2 tokens`,'#f87171');renderAll();
}

// ═══════════════════════════════ MINIGAME ═════════════════════════════════════
let mg={},mgHold=false,mgRaf=null,mgCanvas=null,mgCtx=null,mgClean=null;

function startMG(){
  const di=DW.reduce((pi,w,i)=>{let r=Math.random()*(DW.reduce((a,b)=>a+b,0));for(let j=0;j<DW.length;j++){r-=DW[j];if(r<=0)return j;}return 0;},0);
  // reuse wrand-style
  const t=DW.reduce((a,b)=>a+b,0);let r2=Math.random()*t,di2=0;
  for(let i=0;i<DW.length;i++){r2-=DW[i];if(r2<=0){di2=i;break;}}
  const d=DIFFS[di2];
  mg={diff:d,sliderX:250,zoneX:(500-d.zW)/2,zoneV:d.zSpd*(Math.random()>.5?1:-1),
      prog:mgStartProg(),ndc:(Math.min(3,500/d.zSpd))*(0.35+Math.random()*.65),done:false,result:null};
  mgHold=false;
  gs.stats.mgPlayed=(gs.stats.mgPlayed||0)+1;
  document.getElementById('mz-mg').innerHTML=`
    <div style="font-size:10px;color:#374151;text-transform:uppercase;letter-spacing:2px;margin-bottom:6px;">Earn Charge Minigame</div>
    <canvas id="mgc" width="570" height="290" style="border-radius:10px;display:block;touch-action:none;border:1px solid #1c2433;cursor:pointer;"></canvas>
    <div style="font-size:11px;color:#21262d;margin-top:6px;">Hold to move right · Release to move left</div>`;
  showScr('mg');
  mgCanvas=document.getElementById('mgc');mgCtx=mgCanvas.getContext('2d');
  if(!CanvasRenderingContext2D.prototype.roundRect){
    CanvasRenderingContext2D.prototype.roundRect=function(x,y,w,h,r){
      this.moveTo(x+r,y);this.lineTo(x+w-r,y);this.arcTo(x+w,y,x+w,y+r,r);
      this.lineTo(x+w,y+h-r);this.arcTo(x+w,y+h,x+w-r,y+h,r);
      this.lineTo(x+r,y+h);this.arcTo(x,y+h,x,y+h-r,r);
      this.lineTo(x,y+r);this.arcTo(x,y,x+r,y,r);this.closePath();};
  }
  const onUp=()=>{mgHold=false;if(mg.done)finishMG();};
  const onTE=()=>{mgHold=false;if(mg.done)finishMG();};
  mgCanvas.addEventListener('mousedown',()=>mgHold=true);
  mgCanvas.addEventListener('click',()=>{if(mg.done)finishMG();});
  window.addEventListener('mouseup',onUp);
  mgCanvas.addEventListener('touchstart',e=>{e.preventDefault();mgHold=true;},{passive:false});
  window.addEventListener('touchend',onTE);
  mgClean=()=>{window.removeEventListener('mouseup',onUp);window.removeEventListener('touchend',onTE);};
  let lt=null;
  function loop(ts){
    if(!lt)lt=ts;const dt=Math.min((ts-lt)/1000,.05);lt=ts;
    if(!mg.done){
      mg.sliderX+=(mgHold?mg.diff.sSpd:-mg.diff.sSpd)*dt;
      mg.sliderX=Math.max(0,Math.min(500,mg.sliderX));
      mg.zoneX+=mg.zoneV*dt;const mz=500-mg.diff.zW;
      if(mg.zoneX<0){mg.zoneX=0;mg.zoneV=Math.abs(mg.zoneV)*(0.82+Math.random()*.36);}
      if(mg.zoneX>mz){mg.zoneX=mz;mg.zoneV=-Math.abs(mg.zoneV)*(0.82+Math.random()*.36);}
      mg.ndc-=dt;
      if(mg.ndc<=0){mg.zoneV=mg.diff.zSpd*(Math.random()>.5?1:-1)*(0.6+Math.random()*.8);mg.ndc=(Math.min(3,500/mg.diff.zSpd))*(0.25+Math.random()*.75);}
      const inZ=mg.sliderX>=mg.zoneX&&mg.sliderX<=mg.zoneX+mg.diff.zW;
      mg.prog+=(inZ?mg.diff.fill:-mg.diff.drain)*dt;mg.prog=Math.max(0,Math.min(1,mg.prog));
      if(mg.prog>=1){mg.done=true;mg.result='win';}else if(mg.prog<=0){mg.done=true;mg.result='lose';}
    }
    drawMG();if(!mg.done)mgRaf=requestAnimationFrame(loop);
  }
  mgRaf=requestAnimationFrame(loop);
}
function drawMG(){
  const ctx=mgCtx,bx=55,by=145,BH=15,BW=490;
  ctx.clearRect(0,0,570,290);ctx.fillStyle='#0d1117';ctx.fillRect(0,0,570,290);
  const px=15,py=50,pw=21,ph=185;
  ctx.beginPath();ctx.fillStyle='#161b22';ctx.roundRect(px,py,pw,ph,5);ctx.fill();
  const fh=mg.prog*ph,cr=Math.round(255*(1-mg.prog)),cg=Math.round(215*mg.prog);
  ctx.beginPath();ctx.fillStyle=`rgb(${cr},${cg},25)`;ctx.roundRect(px,py+ph-fh,pw,fh,5);ctx.fill();
  ctx.fillStyle='#21262d';ctx.font='9px sans-serif';ctx.textAlign='center';ctx.fillText('CHARGE',px+pw/2,py-5);
  const rm=mgRewardMult();
  if(rm>1){ctx.beginPath();ctx.fillStyle='#f8717120';ctx.roundRect(42,8,95,22,5);ctx.fill();ctx.fillStyle='#f87171';ctx.font='10px sans-serif';ctx.textAlign='center';ctx.fillText(`×${rm.toFixed(2)} reward`,89,23);}
  const d=mg.diff;
  ctx.beginPath();ctx.fillStyle=d.col+'22';ctx.roundRect(388,8,166,42,7);ctx.fill();
  ctx.strokeStyle=d.col+'77';ctx.lineWidth=1;ctx.stroke();
  ctx.fillStyle=d.col;ctx.font='bold 14px sans-serif';ctx.textAlign='center';ctx.fillText(d.name,471,27);
  const er=(d.reward*rm).toFixed(rm>1?2:0);
  ctx.fillStyle='#4b5563';ctx.font='11px sans-serif';ctx.fillText(`+${er} charge${d.reward>1?'s':''}`,471,44);
  ctx.beginPath();ctx.fillStyle='#161b22';ctx.roundRect(bx,by-BH/2,BW,BH,7);ctx.fill();
  ctx.beginPath();ctx.fillStyle='#3b82f640';ctx.roundRect(bx+mg.zoneX,by-BH/2,d.zW,BH,4);ctx.fill();
  ctx.strokeStyle='#60a5faaa';ctx.lineWidth=1.5;ctx.stroke();
  const inZ=mg.sliderX>=mg.zoneX&&mg.sliderX<=mg.zoneX+d.zW;
  ctx.beginPath();ctx.arc(bx+mg.sliderX,by,10,0,Math.PI*2);
  ctx.fillStyle=inZ?'#22c55e':'#f87171';ctx.fill();
  ctx.strokeStyle=inZ?'#86efacbb':'#fca5a5bb';ctx.lineWidth=2;ctx.stroke();
  ctx.fillStyle='#21262d';ctx.font='11px sans-serif';ctx.textAlign='center';
  ctx.fillText('Keep the slider in the blue zone',285,216);
  ctx.fillStyle=mgHold?'#22c55e66':'#f8717166';
  ctx.fillText(mgHold?'▶ Moving right':'◀ Moving left',285,233);
  if(mg.done){
    ctx.fillStyle='rgba(0,0,0,.84)';ctx.fillRect(0,0,570,290);ctx.textAlign='center';
    if(mg.result==='win'){
      const earned=(d.reward*rm).toFixed(rm>1?2:0);
      ctx.fillStyle='#22c55e';ctx.font='bold 26px sans-serif';ctx.fillText(`+${earned} Charge${d.reward>1?'s':''}!`,285,118);
      if(rm>1){ctx.fillStyle='#f87171';ctx.font='12px sans-serif';ctx.fillText(`(×${rm.toFixed(2)} multiplier)`,285,140);}
      ctx.fillStyle='#6b7280';ctx.font='14px sans-serif';ctx.fillText('Minigame complete!',285,rm>1?162:148);
    }else{
      ctx.fillStyle='#ef4444';ctx.font='bold 26px sans-serif';ctx.fillText('Failed!',285,125);
      ctx.fillStyle='#6b7280';ctx.font='14px sans-serif';ctx.fillText('Bar depleted — no charges earned.',285,155);
    }
    ctx.fillStyle='#374151';ctx.font='11px sans-serif';ctx.fillText('Click or release to continue',285,192);
  }
}
function finishMG(){
  cancelAnimationFrame(mgRaf);if(mgClean){mgClean();mgClean=null;}
  if(mg.result==='win'){
    const rm=mgRewardMult();const earned=mg.diff.reward*rm;
    gs.charges+=earned;gs.stats.chargesEarned=(gs.stats.chargesEarned||0)+earned;
    gs.stats.mgWon=(gs.stats.mgWon||0)+1;saveGS();
    notif(`+${earned.toFixed(rm>1?2:0)} charge${mg.diff.reward>1?'s':''}! (${mg.diff.name})`,mg.diff.col);
  }else{notif('No charges earned.',RC.common);}
  renderAll();
}

// ═══════════════════════════════ FUSING ══════════════════════════════════════
let fzFusions=[],fzMain=null;

function doFuse(){
  const ft=FUSE_TYPES.find(t=>t.id===gs.selectedFuse)||FUSE_TYPES[0];
  if(gs.charges<ft.cost){notif(`Need ${ft.cost}⚡`,'#ef4444');return;}
  const bulk=gs.pShop.bulkfuse?3:1;
  if(gs.charges<ft.cost*bulk){notif(`Need ${ft.cost*bulk}⚡ for Triple Pull`,'#ef4444');return;}
  fzFusions=[];
  const lk=effectiveLuck()+ft.bonus;
  for(let i=0;i<bulk;i++){
    if(gs.charges<ft.cost)break;
    gs.charges-=ft.cost;gs.stats.chSpent=(gs.stats.chSpent||0)+ft.cost;
    gs.stats.fuseCt=(gs.stats.fuseCt||0)+1;
    fzFusions.push(pickFusionWith(lk));
  }
  // sort so rarest shows in animation
  fzFusions.sort((a,b)=>RARITY_ORDER.indexOf(a.rarity)-RARITY_ORDER.indexOf(b.rarity));
  fzMain=fzFusions[0];
  saveGS();
  if(gs.pShop.skipfuse){showFzResult();showScr('fz');}else{startFusing();}
}
function setWord(el,text,col){
  el.innerHTML=`<span style="display:inline-block;color:${col};animation:mz-slideup .22s cubic-bezier(.22,1,.36,1) both;">${text}</span>`;
}
function startFusing(){
  showScr('fz');
  document.getElementById('mz-fz').innerHTML=`
    <div style="text-align:center;animation:mz-fadein .3s ease;width:100%;max-width:560px;padding:24px;">
      <div style="font-size:10px;color:#374151;text-transform:uppercase;letter-spacing:2px;margin-bottom:32px;">Activating Fuse Machine...</div>
      <div style="display:flex;align-items:center;justify-content:center;min-height:60px;">
        <div id="fz-left"  style="flex:1;text-align:right;font-size:30px;font-weight:500;padding-right:14px;overflow:hidden;"></div>
        <div style="font-size:28px;font-weight:300;color:#ffffff33;flex-shrink:0;">X</div>
        <div id="fz-right" style="flex:1;text-align:left;font-size:30px;font-weight:500;padding-left:14px;overflow:hidden;"></div>
      </div>
      <div id="fz-ry" style="font-size:11px;min-height:18px;margin-top:10px;text-transform:capitalize;letter-spacing:.5px;"></div>
    </div>`;
  const leftEl=document.getElementById('fz-left');
  const rightEl=document.getElementById('fz-right');
  const ryEl=document.getElementById('fz-ry');
  const sm=animSpeedMult();
  const total=Math.max(5,Math.floor(26/sm))+Math.floor(Math.random()*Math.max(2,Math.floor(14/sm)));
  const maxDelay=Math.max(40,400/sm),baseDelay=Math.max(20,76/sm);
  let cnt=0;
  function flash(){
    cnt++;const last=cnt>=total;
    let lw,rw,col;
    if(last){const p=fzMain.name.split(' X ');lw=p[0];rw=p[1];col=fzMain.color;ryEl.style.color=col+'99';ryEl.textContent=fzMain.rarity;}
    else{lw=LEFT_WORDS[Math.floor(Math.random()*LEFT_WORDS.length)];rw=RIGHT_WORDS[Math.floor(Math.random()*RIGHT_WORDS.length)];col=Object.values(RC)[Math.floor(Math.random()*6)];ryEl.textContent='';}
    setWord(leftEl,lw,col);setWord(rightEl,rw,col);
    if(last){setTimeout(()=>{showFzResult();},Math.max(250,700/sm));return;}
    setTimeout(flash,baseDelay+Math.pow(cnt/total,1.7)*maxDelay);
  }
  flash();
}
function showFzResult(){
  const f=fzMain,c=f.color,parts=f.name.split(' X ');
  const cm=chargeMult();const isBulk=fzFusions.length>1;
  document.getElementById('mz-fz').innerHTML=`
    <div style="text-align:center;position:relative;padding:20px;max-width:500px;width:100%;">
      <div id="fz-ptc" style="position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);width:420px;height:420px;pointer-events:none;overflow:hidden;"></div>
      <div style="position:relative;z-index:2;animation:mz-fadein .4s ease;">
        <div style="font-size:10px;color:#374151;text-transform:uppercase;letter-spacing:2px;margin-bottom:12px;">${isBulk?'Triple Pull Results':'You obtained:'}</div>
        ${isBulk?`
          <div style="display:flex;justify-content:center;gap:10px;margin-bottom:14px;">
            ${fzFusions.map(f2=>`
              <div style="display:flex;flex-direction:column;align-items:center;gap:4px;">
                <img src="${f2.img}" style="width:64px;height:64px;border-radius:9px;object-fit:cover;border:2px solid ${f2.color}66;" onerror="this.style.display='none'">
                <div style="font-size:9px;color:${f2.color};text-transform:capitalize;">${f2.rarity}</div>
                <div style="font-size:10px;color:white;font-weight:500;">${f2.name.replace(' X ','×')}</div>
              </div>`).join('')}
          </div>`
        :`
          <img src="${f.img}" style="width:100px;height:100px;border-radius:12px;object-fit:cover;border:2px solid ${c}66;margin-bottom:10px;" onerror="this.style.display='none'">
          <div style="font-size:11px;color:${c};text-transform:capitalize;margin-bottom:3px;">${f.rarity}</div>
          <div style="font-size:34px;font-weight:500;color:${c};margin-bottom:4px;">${parts[0]} <span style="color:${c}55;font-weight:300;">X</span> ${parts[1]}</div>`}
        <div style="font-size:11px;color:#374151;margin-bottom:22px;">${isBulk?`${fzFusions.length} fusions added to inventory`:`+${f.cps.toFixed(3)}/s base ${cm>1?`· <span style="color:#f87171;">×${cm.toFixed(2)} eff.</span>`:''}`}</div>
        <button onclick="claimF()" style="padding:10px 28px;background:${c};border:none;color:white;border-radius:10px;cursor:pointer;font-size:14px;font-weight:500;font-family:inherit;">Claim${isBulk?` ${fzFusions.length} Fusions`:' Fusion'}</button>
      </div>
    </div>`;
  spawnPtc(document.getElementById('fz-ptc'),c);
}
function spawnPtc(el,col){
  if(!el)return;
  for(let i=0;i<40;i++){
    const s=3+Math.random()*9,a=Math.random()*Math.PI*2,dist=50+Math.random()*170;
    const tx=Math.cos(a)*dist,ty=Math.sin(a)*dist,dur=(.6+Math.random()*.9).toFixed(2);
    const p=document.createElement('div');
    p.style.cssText=`position:absolute;left:${170+Math.random()*80}px;top:${170+Math.random()*80}px;width:${s}px;height:${s}px;background:${col};border-radius:50%;animation:mz-particle ${dur}s ease-out forwards;--tx:${tx}px;--ty:${ty}px;`;
    el.appendChild(p);
  }
}
function claimF(){
  for(const f of fzFusions){
    gs.stats.fusionsGot=(gs.stats.fusionsGot||0)+1;
    gs.stats.rarityCt[f.rarity]=(gs.stats.rarityCt[f.rarity]||0)+1;
    if(gs.pShop.autosell&&(f.rarity==='common'||f.rarity==='uncommon')){
      const v=sellValue(f.id,'base');gs.charges+=v;
      gs.stats.chargesEarned=(gs.stats.chargesEarned||0)+v;
      gs.stats.sellCt=(gs.stats.sellCt||0)+1;
    }else{addToInv(f.id,'base');}
  }
  const f=fzMain;saveGS();
  notif(fzFusions.length>1?`${fzFusions.length} fusions claimed!`:`${f?.name} claimed!`,f?.color||'#22c55e');
  fzFusions=[];fzMain=null;renderAll();
}

// ═══════════════════════════════ SAVE / LOAD ══════════════════════════════════
function doExport(){
  const blob=new Blob([JSON.stringify(gs,null,2)],{type:'application/json'});
  const url=URL.createObjectURL(blob);
  const a=document.createElement('a');a.href=url;a.download='mergeazaintor_save.json';a.click();URL.revokeObjectURL(url);
}
function doImport(ev){
  const file=ev.target.files[0];if(!file)return;
  const r=new FileReader();
  r.onload=e=>{
    try{
      let data=JSON.parse(e.target.result);data=migrate(data);
      const ms=data.maxSlots||6;
      if(!Array.isArray(data.equipped))data.equipped=new Array(ms).fill(null);
      while(data.equipped.length<ms)data.equipped.push(null);
      gs={...defState(),...data,pShop:{...defState().pShop,...(data.pShop||{})},stats:{...defState().stats,...(data.stats||{}),rarityCt:{...defState().stats.rarityCt,...(data.stats?.rarityCt||{})}}};
      saveGS();notif('Save imported!','#22c55e');renderAll();
    }catch{notif('Invalid save file!','#ef4444');}
  };
  r.readAsText(file);
}
function doReset(){
  if(!confirm('Reset ALL progress? This cannot be undone.'))return;
  gs=defState();saveGS();notif('Reset.','#6b7280');renderAll();
}

// ═══════════════════════════════ INIT ═════════════════════════════════════════
renderAll();
</script>
