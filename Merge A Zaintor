// ═══════════════════════════════ TAB: INVENTORY ═══════════════════════════════
function tabInventory(){
  const inv=sortedInv();
  const total=inv.reduce((s,x)=>s+x.count,0);
  if(!inv.length) return`<div style="color:#21262d;text-align:center;padding:40px 0;font-size:13px;">No fusions yet.<br>Activate the fuse machine!</div>`;
  return`
  <div style="font-size:10px;color:#374151;margin-bottom:10px;">${inv.length} unique stacks · ${total} total fusions</div>
  <div style="display:flex;flex-direction:column;gap:6px;">
    ${inv.map(stack=>{
      const f=getFusion(stack.fusionId);if(!f)return'';
      const t=TIERS[stack.tier];
      const tc=tierColor(stack.tier);
      const borderSt=stack.tier==='rainbow'?'animation:mz-rborder 1.5s linear infinite;border-width:1px;border-style:solid;':`border:1px solid ${tc?tc+'55':f.color+'33'};`;
      const nt=nextTier(stack.tier);
      const canCombine=stack.count>=2&&nt!==null;
      const canEquip=gs.equipped.some(e=>e===null);
      const effCPS=(f.cps*tierMult(stack.tier)*chargeMult()).toFixed(3);
      const sv=sellValue(stack.fusionId,stack.tier);
      return`<div style="display:flex;gap:10px;align-items:center;background:#111827;border-radius:10px;padding:10px;${borderSt}">
        <div style="position:relative;flex-shrink:0;">
          <img src="${f.img}" style="width:48px;height:48px;border-radius:7px;object-fit:cover;" onerror="this.style.display='none'">
          ${stack.tier!=='base'?`<div style="position:absolute;bottom:-4px;left:50%;transform:translateX(-50%);font-size:7px;font-weight:700;${stack.tier==='rainbow'?'animation:mz-rainbow 1.5s linear infinite;':'color:'+(tc||'white')+';'}white-space:nowrap;">${t.label}</div>`:''}
        </div>
        <div style="flex:1;min-width:0;">
          <div style="display:flex;align-items:baseline;gap:5px;">
            <span style="font-size:12px;font-weight:500;color:white;">${f.name}</span>
            <span style="font-size:9px;color:${f.color};text-transform:capitalize;">${f.rarity}</span>
            <span style="margin-left:auto;font-size:13px;font-weight:600;color:${tc||f.color};">×${stack.count}</span>
          </div>
          <div style="font-size:10px;color:#4b5563;margin-top:1px;">+${effCPS}/s eff. · Sell: ${fmt(sv)}⚡ each</div>
          <div style="display:flex;gap:5px;margin-top:7px;flex-wrap:wrap;">
            <button onclick="equipFromInv('${stack.fusionId}','${stack.tier}')" ${canEquip?'':'disabled'} style="padding:4px 9px;font-size:10px;border-radius:5px;background:${canEquip?'#1e3a5f':'#161b22'};border:1px solid ${canEquip?'#60a5fa55':'#21262d'};color:${canEquip?'#60a5fa':'#374151'};cursor:${canEquip?'pointer':'not-allowed'};font-family:inherit;">Equip</button>
            <button onclick="combineFusion('${stack.fusionId}','${stack.tier}')" ${canCombine?'':'disabled'} style="padding:4px 9px;font-size:10px;border-radius:5px;background:${canCombine?(tc?tc+'22':'#2a1f4a'):'#161b22'};border:1px solid ${canCombine?(tc?tc+'55':'#7c3aed55'):'#21262d'};color:${canCombine?(tc||'#c084fc'):'#374151'};cursor:${canCombine?'pointer':'not-allowed'};font-family:inherit;">${canCombine?`Combine → ${TIERS[nt].label||'Bronze'}`:`Combine (need 2)`}</button>
            <button onclick="sellFusion('${stack.fusionId}','${stack.tier}')" style="padding:4px 9px;font-size:10px;border-radius:5px;background:#1a0a0a;border:1px solid #ef444433;color:#f87171;cursor:pointer;font-family:inherit;">Sell 1</button>
