      <button onclick="doPrestige()" ${canP?'':'disabled'} style="padding:9px 14px;background:${canP?'#f87171':'#161b22'};border:${canP?'none':'1px solid #21262d'};color:${canP?'white':'#374151'};border-radius:9px;cursor:${canP?'pointer':'not-allowed'};font-size:13px;font-weight:500;font-family:inherit;flex-shrink:0;align-self:center;${canP?'':'opacity:.4;'}">✦ Prestige</button>
