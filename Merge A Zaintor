  <div style="background:${canP?'#1a0a0a':'#111827'};border:1px solid ${canP?'#f8717166':'#1c2433'};border-radius:12px;padding:14px;${canP?'animation:mz-glow 2.5s ease-in-out infinite;':''}">
    <div style="display:flex;gap:12px;align-items:flex-start;">
      <div style="flex:1;">
        <div style="font-size:13px;font-weight:500;color:${pLevel>0?'#f87171':'#6b7280'};margin-bottom:6px;">✦ Prestige ${pLevel}</div>
        ${pLevel>0?`<div style="display:flex;gap:5px;flex-wrap:wrap;margin-bottom:8px;">
          <span style="background:#fbbf2420;border:1px solid #fbbf2440;color:#fbbf24;font-size:10px;padding:2px 7px;border-radius:4px;">Charges ×${cm.toFixed(2)}</span>
          <span style="background:#34d39920;border:1px solid #34d39940;color:#34d399;font-size:10px;padding:2px 7px;border-radius:4px;">+${pLevel*2} Luck</span>
