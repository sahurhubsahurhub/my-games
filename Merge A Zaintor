<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Merge a Zaintor</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { background: #060a10; display: flex; justify-content: center; min-height: 100vh; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; padding: 20px; }
#mzg { position: relative; width: 100%; max-width: 640px; background: #0d1117; border-radius: 14px; overflow: hidden; color: white; user-select: none; }
#mz-main { min-height: 700px; overflow-y: auto; }
#mz-mg  { display:none; position:absolute; inset:0; background:#0d1117; flex-direction:column; align-items:center; justify-content:center; z-index:10; gap:10px; }
#mz-fz  { display:none; position:absolute; inset:0; background:rgba(0,0,0,.97); align-items:center; justify-content:center; z-index:10; }
#mz-nt  { position:absolute; top:14px; right:14px; z-index:20; pointer-events:none; }
button, label { font-family:inherit; }
.tab { flex:1; padding:10px 2px; background:transparent; border:none; border-bottom:2px solid transparent; color:#374151; font-size:11px; cursor:pointer; transition:all .15s; white-space:nowrap; }
.tab.on { color:white; border-bottom-color:#60a5fa; }
.tab:hover:not(.on) { color:#6b7280; }
@keyframes mz-particle { 0%{transform:translate(0,0) scale(1);opacity:1} 100%{transform:translate(var(--tx),var(--ty)) scale(.15);opacity:0} }
@keyframes mz-pulse    { 0%{opacity:.4} 100%{opacity:1} }
@keyframes mz-spin     { to{transform:rotate(360deg)} }
@keyframes mz-fadein   { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:none} }
@keyframes mz-slideup  { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:none} }
@keyframes mz-glow     { 0%,100%{box-shadow:0 0 8px 2px #f8717133} 50%{box-shadow:0 0 22px 6px #f8717144} }
@keyframes mz-rainbow  { 0%{color:#f87171} 16%{color:#fb923c} 33%{color:#fbbf24} 50%{color:#34d399} 66%{color:#60a5fa} 83%{color:#c084fc} 100%{color:#f87171} }
@keyframes mz-rborder  { 0%{border-color:#f87171} 16%{border-color:#fb923c} 33%{border-color:#fbbf24} 50%{border-color:#34d399} 66%{border-color:#60a5fa} 83%{border-color:#c084fc} 100%{border-color:#f87171} }
</style>
</head>
<body>
<div id="mzg">
  <div id="mz-main"></div>
  <div id="mz-mg"></div>
  <div id="mz-fz"></div>
  <div id="mz-nt"></div>
</div>
<script>
// ═══════════════════════════════ CONSTANTS ════════════════════════════════════
const FUSIONS = [
  {id:'f1', name:'Poor X Rich',         img:'https://i.imgur.com/UnyMMPV.jpeg',rarity:'common',   cps:.05, color:'#9ca3af',weight:500},
  {id:'f2', name:'Country X City',      img:'https://i.imgur.com/Z4lZBkk.jpeg',rarity:'common',   cps:.09, color:'#9ca3af',weight:370},
  {id:'f3', name:'Smart X Dumb',        img:'https://i.imgur.com/O49oLja.jpeg',rarity:'uncommon', cps:.34, color:'#34d399',weight:145},
  {id:'f4', name:'Land X Sky',          img:'https://i.imgur.com/NmA0gYS.png', rarity:'uncommon', cps:.50, color:'#34d399',weight:105},
  {id:'f5', name:'Sword X Shield',      img:'https://i.imgur.com/h6TtziN.jpeg',rarity:'rare',     cps:1.20,color:'#60a5fa',weight:58},
  {id:'f6', name:'Warrior X Mage',      img:'https://i.imgur.com/E2kETek.jpeg',rarity:'rare',     cps:1.85,color:'#60a5fa',weight:38},
  {id:'f7', name:'Love X Hate',         img:'https://i.imgur.com/6uMgo3t.jpeg',rarity:'epic',     cps:5.00,color:'#c084fc',weight:11},
  {id:'f8', name:'Chaos X Order',       img:'https://i.imgur.com/jQLpikB.jpeg',rarity:'epic',     cps:7.80,color:'#c084fc',weight:6},
  {id:'f9', name:'Past X Future',       img:'https://i.imgur.com/P9xmuxR.jpeg',rarity:'legendary',cps:20.0,color:'#fbbf24',weight:1.5},
  {id:'f10',name:'Justice X Corruption',img:'https://i.imgur.com/sbW27j0.jpeg',rarity:'legendary',cps:30.0,color:'#fbbf24',weight:.8},
  {id:'f11',name:'Angelic X Demonic',   img:'https://i.imgur.com/nJuOmUp.jpeg',rarity:'mythic',   cps:85.0,color:'#f87171',weight:.18},
];
const LEFT_WORDS  = ['Poor','Country','Smart','Land','Sword','Warrior','Love','Chaos','Past','Justice','Angelic'];
const RIGHT_WORDS = ['Rich','City','Dumb','Sky','Shield','Mage','Hate','Order','Future','Corruption','Demonic'];
const RC = {common:'#9ca3af',uncommon:'#34d399',rare:'#60a5fa',epic:'#c084fc',legendary:'#fbbf24',mythic:'#f87171'};
const TIER_ORDER = ['base','bronze','silver','gold','diamond','rainbow'];
const TIERS = {
  base:   {label:'',       color:null,      mult:1},
  bronze: {label:'Bronze', color:'#cd7f32', mult:4},
  silver: {label:'Silver', color:'#b8b8b8', mult:12},
  gold:   {label:'Gold',   color:'#ffd700', mult:36},
  diamond:{label:'Diamond',color:'#67e8f9', mult:100},
  rainbow:{label:'Rainbow',color:'rainbow', mult:280},
};
const RARITY_ORDER = ['mythic','legendary','epic','rare','uncommon','common'];
const FUSE_TYPES = [
  {id:'basic',  name:'Basic',  cost:1,  bonus:0,  color:'#60a5fa',desc:'Standard odds'},
  {id:'rare',   name:'Rare',   cost:10, bonus:4,  color:'#c084fc',desc:'+4 luck'},
  {id:'premium',name:'Premium',cost:25, bonus:9,  color:'#fbbf24',desc:'+9 luck'},
  {id:'mythic', name:'Mythic', cost:100,bonus:20, color:'#f87171',desc:'+20 luck'},
];
const PSHOP = [
  {id:'autosell', icon:'🗑️',name:'Common Filter',  desc:'Auto-sell common & uncommon on obtain',   cost:1,max:1},
  {id:'headstart',icon:'🚀',name:'Head Start',      desc:'+10% minigame start progress per level',  cost:2,max:3},
  {id:'minibuff', icon:'🎮',name:'Reward Boost',    desc:'Minigame rewards ×1.5 per level',         cost:2,max:3},
  {id:'skipfuse', icon:'⏩',name:'Instant Fuse',    desc:'Fuse animation skips to result',          cost:3,max:1},
  {id:'bulkfuse', icon:'✖️',name:'Triple Pull',     desc:'Each fuse activation grants 3 fusions',  cost:5,max:1},
];
const DIFFS = [
  {name:'Easy',     reward:1,zSpd:60, zW:120,sSpd:205,fill:.82,drain:.33,col:'#22c55e'},
  {name:'Medium',   reward:2,zSpd:120,zW:88, sSpd:238,fill:.60,drain:.54,col:'#84cc16'},
  {name:'Hard',     reward:3,zSpd:195,zW:66, sSpd:265,fill:.44,drain:.84,col:'#eab308'},
  {name:'Very Hard',reward:4,zSpd:290,zW:48, sSpd:295,fill:.32,drain:1.22,col:'#f97316'},
  {name:'Extreme',  reward:5,zSpd:415,zW:34, sSpd:328,fill:.21,drain:1.88,col:'#ef4444'},
];
const DW = [50,25,14,7,4];

// ═══════════════════════════════ STATE ════════════════════════════════════════
function defState() {
  return {
    charges:0,
    inventory:[],
    equipped:new Array(6).fill(null),
    maxSlots:6,
    luckLevel:0, fuseSpeed:0, prestigeLevel:0, prestigeTokens:0,
    pShop:{autosell:0,headstart:0,minibuff:0,skipfuse:0,bulkfuse:0},
    selectedFuse:'basic',
    autoFuse:false,
    stats:{chargesEarned:0,fusionsGot:0,rarityCt:{},mgPlayed:0,mgWon:0,fuseCt:0,chSpent:0,combineCt:0,sellCt:0,timePlayed:0}
  };
}
function migrate(p) {
  // old inventory was array of full fusion objects
  if (p.inventory?.length && p.inventory[0]?.id && !p.inventory[0]?.fusionId) {
    const ni=[];
    for (const f of p.inventory) {
      const s=ni.find(x=>x.fusionId===f.id&&x.tier==='base');
      if(s) s.count++; else ni.push({fusionId:f.id,tier:'base',count:1});
    }
    p.inventory=ni;
  }
  // old equipped was full fusion objects
  if (p.equipped?.length && p.equipped[0]?.id) {
    p.equipped = p.equipped.map(e=>e?{fusionId:e.id,tier:'base'}:null);
  }
  if (p.luck!==undefined && p.luckLevel===undefined) { p.luckLevel=p.luck; delete p.luck; }
  if (!p.pShop) p.pShop={};
  if (!p.stats) p.stats={};
  if (!p.stats.rarityCt) p.stats.rarityCt={};
  return p;
}
function loadGS() {
  try {
    const s=localStorage.getItem('maz_v3');
    if (s) {
      let p=JSON.parse(s); p=migrate(p);
      const ms=p.maxSlots||6;
      if (!Array.isArray(p.equipped)) p.equipped=new Array(ms).fill(null);
      while (p.equipped.length<ms) p.equipped.push(null);
      return {...defState(),...p,pShop:{...defState().pShop,...(p.pShop||{})},stats:{...defState().stats,...(p.stats||{}),rarityCt:{...defState().stats.rarityCt,...(p.stats?.rarityCt||{})}}};
    }
  } catch(e){}
  return defState();
}
let gs=loadGS();
let _sessionStart=Date.now();
function saveGS() {
  gs.stats.timePlayed=(gs.stats.timePlayed||0)+(Date.now()-_sessionStart);
  _sessionStart=Date.now();
  try{localStorage.setItem('maz_v3',JSON.stringify(gs));}catch(e){}
}
setInterval(saveGS,3000);

// ═══════════════════════════════ FORMULAS ═════════════════════════════════════
const getFusion=id=>FUSIONS.find(f=>f.id===id);
const nextTier=t=>{const i=TIER_ORDER.indexOf(t);return i<TIER_ORDER.length-1?TIER_ORDER[i+1]:null;};
const tierMult=t=>TIERS[t]?.mult||1;
const luckCost=()=>Math.floor(15*Math.pow(1.75,gs.luckLevel));
const speedCost=()=>Math.floor(20*Math.pow(1.80,gs.fuseSpeed));
const slotCost=()=>Math.floor(100*Math.pow(3.5,gs.maxSlots-6));
const prestigeCost=()=>Math.floor(500*Math.pow(3.5,gs.prestigeLevel));
const effectiveLuck=()=>gs.luckLevel+gs.prestigeLevel*2;
const chargeMult=()=>Math.pow(1.30,gs.prestigeLevel);
const animSpeedMult=()=>Math.pow(1.20,gs.prestigeLevel)*(1+gs.fuseSpeed*0.15);
const mgRewardMult=()=>Math.pow(1.5,gs.pShop.minibuff||0)*chargeMult();
const mgStartProg=()=>0.30+(gs.pShop.headstart||0)*0.10;
const sellValue=(fusionId,tier)=>{const f=getFusion(fusionId);return f?Math.max(0.1,f.cps*tierMult(tier)*5):0;};
function rawCPS(){return gs.equipped.reduce((s,e)=>{if(!e)return s;const f=getFusion(e.fusionId);return s+(f?f.cps*tierMult(e.tier):0);},0);}
const effectiveCPS=()=>rawCPS()*chargeMult();
function fmt(n){if(n>=1e12)return(n/1e12).toFixed(2)+'T';if(n>=1e9)return(n/1e9).toFixed(2)+'B';if(n>=1e6)return(n/1e6).toFixed(2)+'M';if(n>=1000)return(n/1000).toFixed(1)+'K';return n.toFixed(2);}
function fmtTime(ms){const s=Math.floor(ms/1000),m=Math.floor(s/60),h=Math.floor(m/60),d=Math.floor(h/24);if(d>0)return`${d}d ${h%24}h`;if(h>0)return`${h}h ${m%60}m`;if(m>0)return`${m}m ${s%60}s`;return`${s}s`;}

// ═══════════════════════════════ INVENTORY ════════════════════════════════════
const getStack=(fusionId,tier)=>gs.inventory.find(s=>s.fusionId===fusionId&&s.tier===tier);
function addToInv(fusionId,tier){const s=getStack(fusionId,tier);if(s)s.count++;else gs.inventory.push({fusionId,tier,count:1});}
function removeFromInv(fusionId,tier,n=1){const s=getStack(fusionId,tier);if(!s)return false;s.count-=n;if(s.count<=0)gs.inventory=gs.inventory.filter(x=>!(x.fusionId===fusionId&&x.tier===tier));return true;}
function sortedInv(){
  return [...gs.inventory].sort((a,b)=>{
    const ta=TIER_ORDER.indexOf(a.tier),tb=TIER_ORDER.indexOf(b.tier);
    if(ta!==tb)return tb-ta;
    const fa=getFusion(a.fusionId),fb=getFusion(b.fusionId);
    const ra=RARITY_ORDER.indexOf(fa?.rarity),rb=RARITY_ORDER.indexOf(fb?.rarity);
    if(ra!==rb)return ra-rb;
    return(fa?.name||'').localeCompare(fb?.name||'');
  });
}

// ═══════════════════════════════ PICK FUSION ══════════════════════════════════
function pickFusionWith(luck){
  const ws=FUSIONS.map(f=>{
    const ri=RARITY_ORDER.length-1-RARITY_ORDER.indexOf(f.rarity);
    let w=f.weight;
    if(f.rarity==='common')w=Math.max(w*Math.pow(0.71,luck),15);
    else w=w*(1+ri*0.18*luck);
    return Math.max(w,0.01);
  });
  const t=ws.reduce((a,b)=>a+b,0);let r=Math.random()*t;
  for(let i=0;i<FUSIONS.length;i++){r-=ws[i];if(r<=0)return FUSIONS[i];}
  return FUSIONS[0];
}

// ═══════════════════════════════ NOTIFICATION ═════════════════════════════════
let ntT=null;
function notif(msg,col='#22c55e'){
  const el=document.getElementById('mz-nt');if(!el)return;
  el.innerHTML=`<div style="background:${col}18;border:1px solid ${col}66;color:${col};padding:8px 13px;border-radius:8px;font-size:12px;font-weight:500;animation:mz-fadein .2s ease;max-width:260px;text-align:right;">${msg}</div>`;
  clearTimeout(ntT);ntT=setTimeout(()=>{if(el)el.innerHTML='';},2800);
}

// ═══════════════════════════════ PASSIVE LOOP ══════════════════════════════════
let lastAutoFuse=0, activeTab='fuse';
setInterval(()=>{
  const c=effectiveCPS();
  if(c>0){
    gs.charges+=c/20;
    gs.stats.chargesEarned=(gs.stats.chargesEarned||0)+c/20;
    const el=document.getElementById('mz-ch');
    if(el)el.textContent=fmt(gs.charges)+'⚡';
  }
  if(gs.autoFuse){
    const now=Date.now();
    const ft=FUSE_TYPES.find(t=>t.id===gs.selectedFuse)||FUSE_TYPES[0];
    const bulk=gs.pShop.bulkfuse?3:1;
    if(now-lastAutoFuse>=1500&&gs.charges>=ft.cost){
      lastAutoFuse=now;
      let triggered=false;
      for(let b=0;b<bulk;b++){
        if(gs.charges<ft.cost)break;
        triggered=true;
        gs.charges-=ft.cost;
        gs.stats.chSpent=(gs.stats.chSpent||0)+ft.cost;
        gs.stats.fuseCt=(gs.stats.fuseCt||0)+1;
        const f=pickFusionWith(effectiveLuck()+ft.bonus);
        gs.stats.fusionsGot=(gs.stats.fusionsGot||0)+1;
        gs.stats.rarityCt[f.rarity]=(gs.stats.rarityCt[f.rarity]||0)+1;
        if(gs.pShop.autosell&&(f.rarity==='common'||f.rarity==='uncommon')){
          const v=sellValue(f.id,'base');
          gs.charges+=v;gs.stats.chargesEarned=(gs.stats.chargesEarned||0)+v;
          gs.stats.sellCt=(gs.stats.sellCt||0)+1;
        } else {
          addToInv(f.id,'base');
        }
      }
      if(triggered&&(activeTab==='fuse'||activeTab==='inventory'))renderAll();
    }
  }
},50);

// ═══════════════════════════════ SCREEN ═══════════════════════════════════════
function showScr(n){
  document.getElementById('mz-main').style.display=n==='main'?'block':'none';
  document.getElementById('mz-mg').style.display=n==='mg'?'flex':'none';
  document.getElementById('mz-fz').style.display=n==='fz'?'flex':'none';
}

// ═══════════════════════════════ TIER HELPERS ═════════════════════════════════
function tierColor(tier){return tier==='rainbow'?null:TIERS[tier]?.color||null;}
function tierBadge(tier){
  if(tier==='base')return'';
  if(tier==='rainbow')return`<span style="font-size:9px;font-weight:700;animation:mz-rainbow 1.5s linear infinite;">${TIERS[tier].label}</span>`;
  return`<span style="font-size:9px;font-weight:700;color:${TIERS[tier].color};">${TIERS[tier].label}</span>`;
}
function tierBorderStyle(tier){
  if(tier==='rainbow')return'animation:mz-rborder 1.5s linear infinite;border-width:1px;border-style:solid;';
  const c=TIERS[tier]?.color;
  return c?`border:1px solid ${c}66;`:'border:1px solid #1c2433;';
}

// ═══════════════════════════════ SLOT HTML ════════════════════════════════════
function slotHTML(e,i){
  if(!e)return`<div style="aspect-ratio:1;border-radius:7px;border:1px solid #161b22;background:#0a0e14;display:flex;align-items:center;justify-content:center;overflow:hidden;"><span style="color:#161b22;font-size:16px;">+</span></div>`;
  const f=getFusion(e.fusionId);if(!f)return'';
  const tc=tierColor(e.tier);
  const borderSt=e.tier==='rainbow'?'animation:mz-rborder 1.5s linear infinite;border-width:1.5px;border-style:solid;':'border:1.5px solid '+(tc?tc+'88':f.color+'55')+';';
  return`<div onclick="unequipSlot(${i})" title="${f.name}${e.tier!=='base'?' ['+TIERS[e.tier].label+']':''} — click to unequip"
    style="aspect-ratio:1;border-radius:7px;background:#111827;display:flex;align-items:center;justify-content:center;cursor:pointer;overflow:hidden;position:relative;${borderSt}">
    <img src="${f.img}" style="width:100%;height:100%;object-fit:cover;opacity:.85;" onerror="this.style.display='none'">
    <div style="position:absolute;inset:0;background:linear-gradient(transparent 35%,#0d111799);"></div>
    ${e.tier!=='base'?`<div style="position:absolute;top:2px;right:2px;${e.tier==='rainbow'?'animation:mz-rainbow 1.5s linear infinite;':'color:'+(tc||'white')+';'}font-size:7px;font-weight:700;">${TIERS[e.tier].label[0]}</div>`:''}
    <div style="position:absolute;bottom:2px;left:0;right:0;text-align:center;font-size:6px;color:${tc||f.color};font-weight:500;padding:0 1px;line-height:1.1;">${f.name.replace(' X ','×')}</div>
  </div>`;
}

// ═══════════════════════════════ RENDER ALL ═══════════════════════════════════
function renderAll(){
  const tabDefs=[
    {id:'fuse',label:'⚗️ Fuse'+(gs.autoFuse?' ●':'')},
    {id:'inventory',label:'🎒 Inv'},
    {id:'upgrades',label:'⬆️ Upgrades'},
    {id:'stats',label:'📊 Stats'},
    {id:'shop',label:'🏪 Shop'},
  ];
  const tabBar=`<div style="display:flex;border-bottom:1px solid #161b22;padding:0 8px;">${tabDefs.map(t=>`<button class="tab ${activeTab===t.id?'on':''}" onclick="setTab('${t.id}')">${t.label}</button>`).join('')}</div>`;
  const content={fuse:tabFuse,inventory:tabInventory,upgrades:tabUpgrades,stats:tabStats,shop:tabShop}[activeTab]?.();

  document.getElementById('mz-main').innerHTML=`
    <div style="padding:18px 20px 10px;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
        <div>
          <div style="font-size:18px;font-weight:500;">Merge a Zaintor</div>
          <div style="font-size:10px;color:#374151;">${gs.prestigeLevel>0?`<span style="color:#f87171;">✦P${gs.prestigeLevel}</span> · `:''}Luck Lv.${gs.luckLevel} · Speed Lv.${gs.fuseSpeed}${gs.prestigeTokens>0?` · <span style="color:#fbbf24;">${gs.prestigeTokens}🪙</span>`:''}</div>
        </div>
        <div style="display:flex;gap:5px;">
          <button onclick="doExport()" style="padding:4px 8px;font-size:11px;background:#161b22;border:1px solid #21262d;color:#4b5563;border-radius:6px;cursor:pointer;">Export</button>
          <label style="padding:4px 8px;font-size:11px;background:#161b22;border:1px solid #21262d;color:#4b5563;border-radius:6px;cursor:pointer;display:inline-block;">Import<input type="file" accept=".json" onchange="doImport(event)" style="display:none;"></label>
          <button onclick="doReset()" style="padding:4px 8px;font-size:11px;background:#161b22;border:1px solid #21262d;color:#4b5563;border-radius:6px;cursor:pointer;">Reset</button>
        </div>
      </div>
      <div style="text-align:center;margin-bottom:12px;">
        <div id="mz-ch" style="font-size:38px;font-weight:500;color:#fbbf24;letter-spacing:-1px;">${fmt(gs.charges)}⚡</div>
        <div style="font-size:11px;color:#374151;margin-top:1px;">${fmt(effectiveCPS())}/sec ${chargeMult()>1?`<span style="color:#f87171;">(×${chargeMult().toFixed(2)})</span>`:''} · ${gs.equipped.filter(Boolean).length} equipped</div>
      </div>
    </div>
    ${tabBar}
    <div style="padding:14px 20px 28px;">${content}</div>`;
  showScr('main');
}
function setTab(t){activeTab=t;renderAll();}

// ═══════════════════════════════ TAB: FUSE ════════════════════════════════════
function tabFuse(){
  const ft=FUSE_TYPES.find(t=>t.id===gs.selectedFuse)||FUSE_TYPES[0];
  const canFuse=gs.charges>=ft.cost;
  const cm=chargeMult();

  // Fuse machine
  const machine=`
  <div style="background:#111827;border-radius:14px;border:1px solid #1c2433;padding:18px 12px;margin-bottom:12px;">
    <div style="display:flex;align-items:center;">
      <div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:6px;">
        <div style="font-size:9px;color:#374151;text-transform:uppercase;letter-spacing:1.5px;">Hector</div>
        <img src="https://i.imgur.com/915PkA8.png" width="70" height="70" style="object-fit:contain;image-rendering:pixelated;" onerror="this.style.cssText='width:70px;height:70px;background:#1e293b;border-radius:8px;display:block;'">
        <div style="width:48px;height:4px;background:#1a2540;border-radius:2px;overflow:hidden;"><div style="width:100%;height:100%;background:#3b82f6;animation:mz-pulse 1.5s ease-in-out infinite alternate;"></div></div>
      </div>
