<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Crack A Zain 🦕</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:wght@400;600;700;800;900&display=swap');

*{box-sizing:border-box;margin:0;padding:0;}

:root{
  --bg:#0d0520;
  --bg2:#160a30;
  --panel:#170d2e;
  --card:#201040;
  --hover:#2c1558;
  --brd:#2e1a50;
  --brd2:#4a2d78;
  --acc:#b96ef7;
  --acc2:#7c3aed;
  --txt:#e8d8ff;
  --dim:#7a6a99;
  --gold:#f5c518;
  --gold2:#e09900;
  --grn:#3ddc84;
  --red:#ff6b6b;
  --font:'Fredoka One',cursive;
  --body:'Nunito',sans-serif;
}

html,body{height:100%;overflow:hidden;background:var(--bg);color:var(--txt);font-family:var(--body);user-select:none;}

/* ── HEADER ── */
#hdr{
  height:52px;background:#0a0318;
  border-bottom:2px solid var(--brd2);
  display:flex;align-items:center;padding:0 14px;gap:12px;
  box-shadow:0 2px 20px rgba(123,58,237,.3);
}
#title{
  font-family:var(--font);font-size:22px;letter-spacing:.5px;
  background:linear-gradient(100deg,#c084fc,#fb923c,#f472b6);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  flex-shrink:0;text-shadow:none;
}
#coins-wrap{display:flex;align-items:center;gap:5px;font-size:16px;font-weight:800;color:var(--gold);flex-shrink:0;font-family:var(--font);}
#flash{font-size:12px;color:var(--grn);min-width:90px;font-weight:700;}
#hdr-btns{margin-left:auto;display:flex;gap:5px;align-items:center;}
.hbtn{
  padding:5px 10px;background:var(--card);border:1px solid var(--brd2);
  color:var(--txt);border-radius:6px;cursor:pointer;font-size:12px;
  font-family:var(--body);font-weight:700;transition:background .12s,border-color .12s;
}
.hbtn:hover{background:var(--hover);border-color:var(--acc);}
.hbtn.red{border-color:#5a1a1a;color:var(--red);}
.hbtn.red:hover{background:#3a0a0a;}

/* ── LAYOUT ── */
#main{display:flex;height:calc(100vh - 52px);overflow:hidden;}
.side{width:238px;background:var(--panel);display:flex;flex-direction:column;flex-shrink:0;overflow:hidden;}
.side.L{border-right:2px solid var(--brd);}
.side.R{border-left:2px solid var(--brd);}
.phdr{
  padding:10px 12px;font-family:var(--font);font-size:14px;color:var(--acc);
  letter-spacing:.06em;background:#0f0825;border-bottom:1px solid var(--brd);flex-shrink:0;
}
.pbody{flex:1;overflow-y:auto;padding:8px;}
.pbody::-webkit-scrollbar{width:4px;}
.pbody::-webkit-scrollbar-thumb{background:var(--brd);border-radius:2px;}

/* ── UPGRADES ── */
.ucard{
  background:var(--card);border:1px solid var(--brd);border-radius:10px;
  padding:9px 10px;margin-bottom:8px;cursor:pointer;
  transition:border-color .15s,background .15s,box-shadow .15s;
}
.ucard:hover:not(.umaxed){border-color:var(--acc);background:var(--hover);box-shadow:0 0 10px rgba(185,110,247,.15);}
.ucard.umaxed{border-color:#6b4a00;cursor:default;}
.urow{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:2px;}
.uname{font-size:13px;font-weight:800;color:var(--txt);}
.ulvl{font-size:10px;color:var(--acc);font-weight:700;}
.udesc{font-size:10.5px;color:var(--dim);margin-bottom:4px;line-height:1.35;}
.ucost{font-size:12px;font-weight:800;color:var(--gold);}
.ucost.dim{opacity:.45;}
.umxtxt{font-size:12px;color:#fb923c;font-weight:800;}

/* ── CENTER ── */
#center{
  flex:1;position:relative;display:flex;flex-direction:column;
  align-items:center;justify-content:center;gap:14px;
  background:radial-gradient(ellipse at 50% 38%, #251050 0%, #0d0520 72%);
  overflow:hidden;
}

/* Animated stars */
#stars{position:absolute;inset:0;pointer-events:none;}
.star{position:absolute;border-radius:50%;background:#fff;animation:twinkle var(--d) var(--delay) infinite alternate;}
@keyframes twinkle{0%{opacity:.05;}100%{opacity:.35;}}

/* Ground */
#ground{
  position:absolute;bottom:0;left:0;right:0;height:90px;
  background:linear-gradient(180deg,transparent 0%,#0d0318 100%);
  border-top:1px solid #2e1a50;
}
#ground::before{
  content:'';position:absolute;top:-1px;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,#7c3aed,transparent);
}

/* CRACK text */
#crack-txt{
  position:absolute;top:7%;left:50%;transform:translateX(-50%);
  font-family:var(--font);font-size:58px;letter-spacing:8px;
  color:#fef08a;text-shadow:4px 4px 0 #854d0e,-1px -1px 0 #713f12,0 0 30px #fbbf24cc;
  pointer-events:none;display:none;z-index:10;white-space:nowrap;
}
#crack-txt.show{display:block;animation:crackIn .45s cubic-bezier(.175,.885,.32,1.275) both;}
@keyframes crackIn{0%{transform:translateX(-50%) scale(.15) rotate(-12deg);opacity:0;}65%{transform:translateX(-50%) scale(1.14) rotate(4deg);opacity:1;}100%{transform:translateX(-50%) scale(1) rotate(0);opacity:1;}}

/* EGG */
#egg-area{display:flex;flex-direction:column;align-items:center;gap:10px;z-index:2;position:relative;}
#egg-badge{
  font-family:var(--font);font-size:14px;padding:3px 14px;
  border-radius:20px;border:1.5px solid currentColor;letter-spacing:.04em;
}
#egg-img{
  width:160px;height:160px;object-fit:contain;cursor:pointer;
  image-rendering:pixelated;transition:filter .15s;
  filter:drop-shadow(0 0 22px rgba(185,110,247,.35));
}
#egg-img:hover{transform:scale(1.04);}
@keyframes shake{
  0%{transform:translate(0,0)rotate(0);}
  12%{transform:translate(-7px,3px)rotate(-5deg);}
  25%{transform:translate(7px,-3px)rotate(5deg);}
  37%{transform:translate(-6px,2px)rotate(-4deg);}
  50%{transform:translate(6px,-1px)rotate(3deg);}
  62%{transform:translate(-4px,1px)rotate(-2deg);}
  75%{transform:translate(3px,0)rotate(1deg);}
  87%{transform:translate(-2px,0)rotate(-.5deg);}
  100%{transform:translate(0,0)rotate(0);}
}
#egg-img.shaking{animation:shake .38s ease-out;}

/* HP Bar */
#hp-wrap{width:200px;}
#hp-bg{
  width:100%;height:16px;background:#080215;
  border:1.5px solid var(--brd2);border-radius:8px;overflow:hidden;
  box-shadow:0 0 8px rgba(0,0,0,.4) inset;
}
#hp-fill{height:100%;border-radius:8px;background:linear-gradient(90deg,#dc2626,#f87171);transition:width .07s linear;}
#hp-txt{font-size:11px;color:var(--dim);text-align:center;margin-top:3px;font-weight:700;}

/* EQUIPPED ZAIN */
#eq-area{display:flex;flex-direction:column;align-items:center;gap:5px;z-index:2;position:relative;}
#zain-img{width:100px;height:100px;object-fit:contain;image-rendering:pixelated;}
@keyframes lunge{
  0%{transform:translateY(0) scaleX(1) scaleY(1);}
  28%{transform:translateY(-55px) scaleX(1.1) scaleY(.9);}
  60%{transform:translateY(-20px) scaleX(.94) scaleY(1.08);}
  100%{transform:translateY(0) scaleX(1) scaleY(1);}
}
#zain-img.lunging{animation:lunge .4s ease-in-out;}
#zain-lbl{font-family:var(--font);font-size:13px;color:var(--grn);}
#zain-dps{font-size:10.5px;color:var(--dim);font-weight:700;}
#unequip-btn{
  font-size:10px;padding:2px 8px;background:#1a0d30;border:1px solid var(--brd2);
  color:var(--dim);border-radius:5px;cursor:pointer;font-family:var(--body);font-weight:700;
}
#unequip-btn:hover{border-color:var(--red);color:var(--red);background:#2a0a0a;}

/* FLOATING DAMAGE */
.dflt{
  position:absolute;pointer-events:none;font-weight:900;font-family:var(--font);
  z-index:20;animation:dflt .9s ease-out forwards;
  text-shadow:1px 1px 3px rgba(0,0,0,.7);
}
@keyframes dflt{0%{transform:translate(-50%,0);opacity:1;}100%{transform:translate(-50%,-75px);opacity:0;}}

/* HATCH OVERLAY */
#hatch-ov{
  position:absolute;inset:0;background:rgba(6,1,15,.9);
  backdrop-filter:blur(8px);display:none;align-items:center;justify-content:center;z-index:50;
}
#hatch-ov.show{display:flex;}
#hatch-box{
  background:linear-gradient(145deg,#1a0a38,#250d4a);
  border:2px solid var(--acc);border-radius:20px;padding:30px 52px;text-align:center;
  box-shadow:0 0 50px rgba(185,110,247,.35),0 0 100px rgba(185,110,247,.1);
  animation:popIn .42s cubic-bezier(.175,.885,.32,1.275);
}
@keyframes popIn{0%{transform:scale(.25) rotate(-10deg);opacity:0;}100%{transform:scale(1) rotate(0);opacity:1;}}
#hatch-sub{font-size:11px;color:var(--dim);letter-spacing:.14em;margin-bottom:14px;font-weight:800;text-transform:uppercase;}
#hatch-img{width:130px;height:130px;object-fit:contain;image-rendering:pixelated;}
#hatch-name{font-family:var(--font);font-size:28px;margin-top:12px;letter-spacing:.04em;}
#hatch-rar{font-size:13px;margin-top:4px;font-weight:800;letter-spacing:.06em;}
#hatch-coin{font-size:17px;color:var(--gold);margin-top:10px;font-weight:800;}

/* QUICK LOOT TOAST */
#ql-toast{
  position:absolute;top:14px;right:14px;
  background:linear-gradient(135deg,#1a0a38,#260e4a);
  border:1.5px solid var(--acc);border-radius:12px;
  padding:8px 12px;display:flex;align-items:center;gap:10px;
  z-index:40;pointer-events:none;
  box-shadow:0 0 18px rgba(185,110,247,.3);
  opacity:0;transform:translateX(30px);
  transition:opacity .22s ease,transform .22s ease;
  min-width:180px;
}
#ql-toast.show{opacity:1;transform:translateX(0);}
#ql-toast-img{width:44px;height:44px;object-fit:contain;image-rendering:pixelated;flex-shrink:0;}
#ql-toast-info{flex:1;min-width:0;}
#ql-toast-sub{font-size:9px;color:var(--dim);font-weight:800;letter-spacing:.1em;text-transform:uppercase;margin-bottom:1px;}
#ql-toast-name{font-family:var(--font);font-size:14px;letter-spacing:.03em;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
#ql-toast-rar{font-size:10px;font-weight:800;letter-spacing:.05em;}
#ql-toast-coin{font-size:11px;color:var(--gold);font-weight:800;margin-top:1px;}

/* FEATURES SECTION */
#feat-section{padding:8px;border-top:1px solid var(--brd);flex-shrink:0;}
.feat-hdr{font-size:11px;font-weight:800;color:var(--dim);letter-spacing:.08em;text-transform:uppercase;margin-bottom:6px;padding:0 2px;}
.feat-card{
  background:var(--card);border:1.5px solid var(--brd);border-radius:10px;
  padding:9px 10px;cursor:pointer;transition:border-color .15s,background .15s,box-shadow .15s;
}
.feat-card:hover:not(.feat-owned){border-color:var(--gold);background:var(--hover);box-shadow:0 0 10px rgba(245,197,24,.12);}
.feat-card.feat-owned{border-color:#2a6b3a;background:#0d2215;cursor:default;}
.feat-row{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:2px;}
.feat-name{font-size:13px;font-weight:800;}
.feat-badge-owned{font-size:10px;color:var(--grn);font-weight:800;}
.feat-desc{font-size:10.5px;color:var(--dim);margin-bottom:4px;line-height:1.35;}
.feat-cost{font-size:12px;font-weight:800;color:var(--gold);}
.feat-cost.dim{opacity:.4;}

/* INVENTORY */
.icard{
  background:var(--card);border:1px solid var(--brd);border-radius:10px;
  padding:8px 9px;margin-bottom:8px;display:flex;align-items:center;gap:8px;
  cursor:pointer;transition:border-color .15s,background .15s,box-shadow .15s;
}
.icard:hover{border-color:var(--acc);background:var(--hover);}
.icard.eq{border-color:var(--gold);box-shadow:0 0 12px rgba(245,197,24,.15);}
.idimg{width:50px;height:50px;object-fit:contain;image-rendering:pixelated;flex-shrink:0;}
.iinfo{flex:1;min-width:0;}
.iname{font-size:12.5px;font-weight:800;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.ieqb{font-size:9px;font-weight:800;color:var(--gold);letter-spacing:.07em;text-transform:uppercase;}
.imeta{font-size:10px;color:var(--dim);font-weight:700;}
.idmg{font-size:11px;color:var(--grn);font-weight:800;}
.iubtn{
  margin-top:4px;font-size:10px;padding:2px 7px;background:#1e1005;
  border:1px solid #7c4f0a;color:var(--gold);border-radius:5px;
  cursor:pointer;font-family:var(--body);font-weight:800;transition:background .12s;
  display:inline-block;
}
.iubtn:hover{background:#3d2308;}
.iubtn.dim{opacity:.4;cursor:not-allowed;}
.icnt{
  background:var(--brd2);font-size:11px;font-weight:800;
  padding:2px 7px;border-radius:8px;flex-shrink:0;align-self:flex-start;
  font-family:var(--font);
}
.iempty{color:var(--dim);text-align:center;font-size:13px;padding:30px 8px;line-height:1.9;font-weight:700;}

/* BOSS EGG */
#boss-counter{
  font-size:11px;font-weight:800;color:var(--dim);letter-spacing:.04em;
  min-height:16px;transition:color .3s;
}
#boss-counter.warn{color:#fb923c;animation:bcWarn 1s ease-in-out infinite alternate;}
@keyframes bcWarn{0%{opacity:.65;}100%{opacity:1;color:#fbbf24;}}

#egg-img.boss-pulse{
  animation:bossPulse 1.1s ease-in-out infinite!important;
}
@keyframes bossPulse{0%{transform:scale(1);}50%{transform:scale(1.05);}100%{transform:scale(1);}}

.egg-badge-boss{
  background:linear-gradient(90deg,#7f1d1d,#dc2626,#7f1d1d)!important;
  color:#fff!important;border-color:#ef4444!important;
  animation:bossGlow 1.4s ease-in-out infinite alternate;
}
@keyframes bossGlow{0%{box-shadow:0 0 8px #ef444466;}100%{box-shadow:0 0 22px #ef4444cc,0 0 44px #ef444433;}}

#boss-timer-wrap{width:200px;display:none;margin-top:5px;}
#boss-timer-bg{width:100%;height:10px;background:#150005;border:1px solid #7f1d1d;border-radius:5px;overflow:hidden;}
#boss-timer-fill{height:100%;border-radius:5px;background:linear-gradient(90deg,#ef4444,#fb923c);transition:width 1s linear;}
#boss-timer-txt{font-size:10px;color:#fb923c;text-align:center;margin-top:2px;font-weight:800;letter-spacing:.04em;}

/* BOSS ESCAPE */
#boss-esc-ov{
  position:absolute;inset:0;background:rgba(50,0,0,.88);backdrop-filter:blur(8px);
  display:none;align-items:center;justify-content:center;z-index:55;
}
#boss-esc-ov.show{display:flex;}
#boss-esc-box{text-align:center;animation:popIn .35s cubic-bezier(.175,.885,.32,1.275);}
#boss-esc-icon{font-size:72px;line-height:1;}
#boss-esc-title{font-family:var(--font);font-size:40px;color:#ef4444;letter-spacing:5px;
  text-shadow:0 0 30px #ef4444,0 0 60px #ef444455;margin-top:6px;}
#boss-esc-sub{font-size:13px;color:#fca5a5;margin-top:8px;font-weight:700;}

/* BOSS VICTORY in hatch box */
#hatch-boss-badge{
  display:none;font-family:var(--font);font-size:12px;letter-spacing:.08em;
  color:#ef4444;margin-bottom:6px;
}

/* PRESTIGE */
#prestige-section{
  padding:8px;border-top:1px solid var(--brd);flex-shrink:0;
  background:linear-gradient(180deg,transparent,rgba(120,80,0,.06));
}
.pres-hdr{font-size:11px;font-weight:800;color:var(--dim);letter-spacing:.08em;text-transform:uppercase;margin-bottom:6px;padding:0 2px;}
#pres-box{
  background:var(--card);border:1.5px solid var(--brd);border-radius:10px;padding:9px 10px;
  transition:border-color .3s,box-shadow .3s;
}
#pres-box.ready{border-color:var(--gold)!important;box-shadow:0 0 14px rgba(245,197,24,.2);}
.prow{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:3px;}
.pkey{font-size:11px;color:var(--dim);font-weight:700;}
.pval{font-size:11px;font-weight:800;color:var(--acc);}
.pval.gold{color:var(--gold);}
#pres-prog-bg{
  width:100%;height:6px;background:#0a0418;border:1px solid var(--brd);
  border-radius:3px;overflow:hidden;margin:5px 0 3px;
}
#pres-prog{height:100%;background:linear-gradient(90deg,#a16207,#f5c518);border-radius:3px;transition:width .4s;}
#pres-prog-txt{font-size:10px;color:var(--dim);text-align:center;font-weight:700;margin-bottom:6px;}
#pres-btn{
  width:100%;padding:7px 0;
  background:linear-gradient(90deg,#78350f,#92400e);
  border:1.5px solid var(--gold);color:var(--gold);border-radius:7px;
  cursor:pointer;font-family:var(--font);font-size:14px;letter-spacing:.04em;
  transition:all .15s;
}
#pres-btn:hover:not(:disabled){background:linear-gradient(90deg,#a16207,#ca8a04);box-shadow:0 0 14px rgba(245,197,24,.3);}
#pres-btn:disabled{opacity:.38;cursor:not-allowed;}
#pres-warn{font-size:10px;color:#fb923c;text-align:center;margin-top:4px;font-weight:700;display:none;}

/* SCALES in header */
#scales-wrap{
  display:flex;align-items:center;gap:5px;font-size:13px;font-weight:800;color:#c8a000;
  background:rgba(100,65,0,.22);padding:3px 10px;border-radius:20px;
  border:1px solid #6b4a00;flex-shrink:0;
}

/* PRESTIGE FLASH */
#pres-flash{
  position:fixed;inset:0;pointer-events:none;z-index:300;opacity:0;
  background:radial-gradient(ellipse at center,rgba(245,197,24,.55) 0%,rgba(251,146,60,.2) 50%,transparent 75%);
}
#pres-flash.go{animation:presFlash .9s ease-out forwards;}
@keyframes presFlash{0%{opacity:1;}100%{opacity:0;}}

/* STATS */
#stats-box{
  padding:8px 10px;border-top:1px solid var(--brd);background:#0f0825;flex-shrink:0;
}
.srow{display:flex;justify-content:space-between;font-size:10.5px;color:var(--dim);font-weight:700;padding:1px 0;}
.sval{color:var(--acc);}

/* COMBO */
#combo-wrap{
  display:flex;flex-direction:column;align-items:center;gap:3px;
  opacity:0;transition:opacity .25s;pointer-events:none;
}
#combo-wrap.active{opacity:1;}
#combo-bar-bg{
  width:160px;height:8px;background:#0a0418;border:1px solid var(--brd2);
  border-radius:4px;overflow:hidden;
}
#combo-bar-fill{
  height:100%;border-radius:4px;
  background:linear-gradient(90deg,#7c3aed,#c084fc,#f472b6);
  transition:width .12s ease-out;
}
#combo-label{
  font-family:var(--font);font-size:15px;color:#f472b6;letter-spacing:.04em;
  text-shadow:0 0 10px #f472b688;
}

/* FUSION */
.fuse-btn{
  margin-top:3px;font-size:10px;padding:2px 7px;
  background:#0d1a2e;border:1px solid #1e40af;color:#93c5fd;
  border-radius:5px;cursor:pointer;font-family:var(--body);font-weight:800;
  transition:background .12s;display:inline-block;
}
.fuse-btn:hover{background:#1e3a5f;}
.fusion-badge{
  font-size:9px;font-weight:800;color:#93c5fd;letter-spacing:.05em;
  text-transform:uppercase;
}
.fusion-glow{filter:drop-shadow(0 0 6px #60a5faaa)!important;}

/* CORRUPTION */
.egg-badge-corrupt{
  background:linear-gradient(90deg,#1c1006,#3b1f00,#1c1006)!important;
  color:#fb923c!important;border-color:#92400e!important;
  animation:corruptGlow 2s ease-in-out infinite alternate;
}
@keyframes corruptGlow{0%{box-shadow:0 0 6px #92400e55;}100%{box-shadow:0 0 18px #f97316aa,0 0 35px #f9731633;}}
.egg-img-corrupt{
  filter:drop-shadow(0 0 16px #f97316aa) sepia(.6) hue-rotate(-20deg) saturate(1.5)!important;
}

/* NO EGG placeholder */
#egg-placeholder{font-family:var(--font);font-size:18px;color:var(--dim);text-align:center;}
</style>
</head>
<body>

<div id="hdr">
  <div id="title">🦕 CRACK A ZAIN</div>
  <div id="coins-wrap">💰 <span id="coins-el">0</span></div>
  <div id="scales-wrap">⚖ <span id="scales-el">0</span> <span id="scales-mult-el" style="font-size:10px;opacity:.8"></span></div>
  <div id="flash"></div>
  <div id="hdr-btns">
    <button class="hbtn" onclick="saveGame()">💾 Save</button>
    <button class="hbtn" onclick="loadGame()">📂 Load</button>
    <button class="hbtn" onclick="exportGame()">📤 Export</button>
    <label class="hbtn" style="cursor:pointer;display:inline-flex;align-items:center">
      📥 Import
      <input type="file" accept=".json" style="display:none" onchange="importGame(event)">
    </label>
    <button class="hbtn red" onclick="resetGame()">🗑 Reset</button>
  </div>
</div>
<div id="pres-flash"></div>

<div id="main">

  <!-- LEFT: UPGRADES -->
  <div class="side L">
    <div class="phdr">⚡ UPGRADES</div>
    <div class="pbody" id="upg-list"></div>
    <div id="feat-section">
      <div class="feat-hdr">🌟 Features</div>
      <div id="feat-list"></div>
    </div>
    <div id="prestige-section">
      <div class="pres-hdr">⚖ Prestige</div>
      <div id="pres-box">
        <div class="prow"><span class="pkey">Prestiges</span><span class="pval" id="pres-count">0</span></div>
        <div class="prow"><span class="pkey">Ancient Scales</span><span class="pval gold" id="pres-scales">0</span></div>
        <div class="prow"><span class="pkey">Scale Bonus</span><span class="pval" id="pres-mult">×1.00</span></div>
        <div id="pres-prog-bg"><div id="pres-prog" style="width:0%"></div></div>
        <div id="pres-prog-txt">Earn coins to unlock</div>
        <button id="pres-btn" disabled onclick="doPrestige()">⚖ PRESTIGE</button>
        <div id="pres-warn">⚠ Resets coins, upgrades &amp; collection</div>
