        <div id="boss-timer-bg"><div id="boss-timer-fill" style="width:100%"></div></div>
        <div id="boss-timer-txt">60s</div>
      </div>
      <div id="combo-wrap">
        <div id="combo-label">×1.0 COMBO</div>
        <div id="combo-bar-bg"><div id="combo-bar-fill" style="width:0%"></div></div>
      </div>
