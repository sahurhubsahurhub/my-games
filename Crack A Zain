    <div id="eq-area">
      <img id="zain-img" src="" alt="" style="display:none">
      <div id="zain-lbl" style="display:none"></div>
      <div id="zain-dps" style="display:none"></div>
      <button id="unequip-btn" style="display:none" onclick="unequipZain()">✖ Unequip</button>
    </div>

    <!-- Quick Loot toast -->
    <div id="ql-toast">
      <img id="ql-toast-img" src="" alt="">
      <div id="ql-toast-info">
        <div id="ql-toast-sub">Hatched!</div>
        <div id="ql-toast-name"></div>
        <div id="ql-toast-rar"></div>
        <div id="ql-toast-coin"></div>
      </div>
    </div>

    <!-- Hatch overlay -->
    <div id="hatch-ov">
      <div id="hatch-box">
        <div id="hatch-boss-badge">👑 BOSS DEFEATED!</div>
        <div id="hatch-corrupt-badge" style="display:none;font-family:var(--font);font-size:12px;color:#fb923c;margin-bottom:5px;letter-spacing:.08em;">🌑 CORRUPTED EGG DROP</div>
        <div id="hatch-sub">✨ A Zainasaurus Hatched! ✨</div>
        <img id="hatch-img" src="" alt="">
        <div id="hatch-name"></div>
        <div id="hatch-rar"></div>
        <div id="hatch-coin"></div>
      </div>
    </div>

    <!-- Boss escape overlay -->
    <div id="boss-esc-ov">
      <div id="boss-esc-box">
        <div id="boss-esc-icon">💨</div>
        <div id="boss-esc-title">ESCAPED!</div>
        <div id="boss-esc-sub">The Boss Egg fled before you could crack it!</div>
      </div>
    </div>
  </div>

  <!-- RIGHT: COLLECTION -->
  <div class="side R">
    <div class="phdr">🎒 COLLECTION</div>
    <div class="pbody" id="inv-list"></div>
    <div id="stats-box">
      <div class="srow">Eggs Hatched: <span class="sval" id="s-hatched">0</span></div>
      <div class="srow">Total Clicks: <span class="sval" id="s-clicks">0</span></div>
      <div class="srow">Coins Earned: <span class="sval" id="s-earned">0</span></div>
    </div>
  </div>

</div>

<script>
// ════════════════════════════════════════════
// DATA
// ════════════════════════════════════════════
const EGGS=[
  {name:'Common',   color:'#9ca3af',glow:'rgba(156,163,175,.4)', hp:60,    cMin:5,    cMax:20,    ni:'https://i.imgur.com/lqJYx0Q.png',ci:'https://i.imgur.com/uT9ly7q.png'},
  {name:'Uncommon', color:'#4ade80',glow:'rgba(74,222,128,.4)',  hp:300,   cMin:40,   cMax:100,   ni:'https://i.imgur.com/J6agEeS.png',ci:'https://i.imgur.com/D9yTgyQ.png'},
  {name:'Rare',     color:'#60a5fa',glow:'rgba(96,165,250,.42)', hp:1000,  cMin:150,  cMax:380,   ni:'https://i.imgur.com/yQ0q56H.png',ci:'https://i.imgur.com/vfO4u3X.png'},
  {name:'Epic',     color:'#c084fc',glow:'rgba(192,132,252,.45)',hp:3500,  cMin:700,  cMax:1700,  ni:'https://i.imgur.com/h49yHXy.png',ci:'https://i.imgur.com/idkFXXW.png'},
  {name:'Legendary',color:'#fb923c',glow:'rgba(251,146,60,.45)', hp:12000, cMin:3000, cMax:7500,  ni:'https://i.imgur.com/uaaf0qj.png',ci:'https://i.imgur.com/etjhxCv.png'},
  {name:'Mythic',   color:'#f87171',glow:'rgba(248,113,113,.5)', hp:48000, cMin:11000,cMax:30000, ni:'https://i.imgur.com/VpwQmnF.png',ci:'https://i.imgur.com/2hUJ1mr.png'},
];

const ZAINS=[
  {name:'Zainken',       img:'https://i.imgur.com/VHziNFO.png',baseDmg:1,    rar:'Common',   color:'#9ca3af'},
  {name:'Zainzard',      img:'https://i.imgur.com/snCgnF2.png',baseDmg:3,    rar:'Uncommon', color:'#4ade80'},
  {name:'Zainptor',      img:'https://i.imgur.com/Nzu9t1i.png',baseDmg:8,    rar:'Uncommon', color:'#4ade80'},
  {name:'Zainodactyl',   img:'https://i.imgur.com/yQvCRy4.png',baseDmg:20,   rar:'Rare',     color:'#60a5fa'},
  {name:'Zankalosaurus', img:'https://i.imgur.com/mXrTYW5.png',baseDmg:55,   rar:'Rare',     color:'#60a5fa'},
  {name:'Ztegosaurus',   img:'https://i.imgur.com/bNau8oa.png',baseDmg:130,  rar:'Epic',     color:'#c084fc'},
  {name:'Trizainatops',  img:'https://i.imgur.com/EgsY6eU.png',baseDmg:330,  rar:'Epic',     color:'#c084fc'},
  {name:'Z-Rex',         img:'https://i.imgur.com/8j76MB3.png',baseDmg:850,  rar:'Legendary',color:'#fb923c'},
  {name:'Zaingon',       img:'https://i.imgur.com/xmybbqU.png',baseDmg:2200, rar:'Legendary',color:'#fb923c'},
  {name:'Zainzilla',     img:'https://i.imgur.com/iGf9vCf.png',baseDmg:6000, rar:'Mythic',   color:'#f87171'},
  {name:'Zaindorah',     img:'https://i.imgur.com/xABek3R.png',baseDmg:18000,rar:'Mythic',   color:'#f87171'},
];

// Drop weights [egg rarity 0-5][zain index 0-10]
const DROPS=[
  [80,15, 5, 0, 0, 0, 0, 0, 0, 0, 0],
  [30,35,26, 8, 1, 0, 0, 0, 0, 0, 0],
  [ 8,22,33,23, 9, 3, 1, 0, 0, 0, 0],
  [ 2, 7,18,28,24,13, 6, 2, 0, 0, 0],
  [ 0, 2, 7,16,26,26,14, 7, 2, 0, 0],
  [ 0, 0, 2, 7,14,22,23,18,10, 3, 1],
];

// Egg spawn weights per luck level [0-20][egg 0-5]
// All rarities always have some chance — luck shifts weight toward rarer eggs
const LUCK=[
  [84, 8, 4, 2, 1, 1],  //  0
  [75,12, 7, 3, 2, 1],  //  1
  [66,15, 9, 5, 3, 2],  //  2
  [57,18,12, 7, 4, 2],  //  3
  [49,20,14, 9, 5, 3],  //  4
  [41,21,16,12, 7, 3],  //  5
  [34,22,18,14, 8, 4],  //  6
  [27,22,20,17,10, 4],  //  7
  [21,21,22,19,12, 5],  //  8
  [16,20,23,22,13, 6],  //  9
  [12,18,24,24,15, 7],  // 10
  [ 9,16,24,26,17, 8],  // 11
  [ 6,13,23,28,20,10],  // 12
  [ 4,11,22,29,23,11],  // 13
  [ 3, 8,20,30,26,13],  // 14
  [ 2, 6,17,29,29,17],  // 15
  [ 1, 5,14,27,32,21],  // 16
  [ 1, 3,11,24,35,26],  // 17
  [ 1, 2, 8,20,38,31],  // 18
  [ 1, 1, 5,16,40,37],  // 19
  [ 0, 1, 3,12,39,45],  // 20
];

// ════════════════════════════════════════════
// BOSS & PRESTIGE CONSTANTS
// ════════════════════════════════════════════
const BOSS_EVERY       = 15;
const BOSS_TIMER_SECS  = 60;
const BOSS_HP_MULT     = 10;
const BOSS_COIN_MULT   = 5;
const PRESTIGE_BASE    = 50000;
const PRESTIGE_SCALE   = 2.5;
const COINS_PER_SCALE  = 10000;
const SCALE_BONUS      = 0.07;
const COMBO_MAX        = 5.0;   // max combo multiplier
const COMBO_GAIN       = 0.4;   // per click
const COMBO_DECAY      = 0.25;  // per second
const CORRUPT_CHANCE   = 0.15;  // 15% chance when eggLuck >= 10
const CORRUPT_HP_MULT  = 5;     // HP multiplier for corrupted eggs

const UDEFS=[
  {id:'clickPower', name:'🖱 Click Power',  bCost:25,  cMult:1.25, max:Infinity,
   desc:l=>`${fmt(cDmg(l))} → ${fmt(cDmg(l+1))} dmg/click`},
  {id:'attackPower',name:'⚔ Attack Power', bCost:75,  cMult:1.35, max:Infinity,
   desc:l=>`×${aPow(l).toFixed(2)} → ×${aPow(l+1).toFixed(2)} Zain damage`},
  {id:'attackSpeed',name:'⚡ Attack Speed', bCost:50,  cMult:1.30, max:Infinity,
   desc:l=>`${(1000/aInt(l)).toFixed(2)} → ${(1000/aInt(l+1)).toFixed(2)} attacks/sec`},
  {id:'moneyMult',  name:'💰 Money Multi',  bCost:200, cMult:1.50, max:Infinity,
   desc:l=>`×${mMlt(l).toFixed(2)} → ×${mMlt(l+1).toFixed(2)} coin drops`},
  {id:'eggLuck',    name:'🍀 Egg Luck',     bCost:500, cMult:2.20, max:20,
   desc:l=>{
     if(l>=20)return'Maximum egg luck achieved!';
     const w=LUCK[Math.min(l,20)];
     return EGGS.map((e,i)=>`${e.name}:${w[i]}%`).join(' ');
   }},
];

// ════════════════════════════════════════════
// STAT HELPERS
// ════════════════════════════════════════════
const aPow =(l)=>Math.pow(1.25,l);
const aInt =(l)=>Math.max(150,Math.floor(2000*Math.pow(0.85,l)));
const mMlt =(l)=>Math.pow(1.35,l);
const Zain =(n)=>ZAINS.find(z=>z.name===n);
const scalesMult=()=>1+G.prestige.scales*SCALE_BONUS;
const cDmg=(l)=>Math.max(1,Math.floor(Math.pow(1.65,l)*scalesMult()));

function zDmg(name){
  const z=Zain(name); if(!z)return 0;
  const inv=G.inv[name]; if(!inv)return 0;
  const lv=inv.level||0;
  const fusions=inv.fusions||0;
  return Math.floor(z.baseDmg*Math.pow(1.65,lv)*aPow(G.up.attackPower)*scalesMult()*Math.pow(2,fusions));
}
function uCost(id){const d=UDEFS.find(d=>d.id===id);return Math.floor(d.bCost*Math.pow(d.cMult,G.up[id]));}
function zuCost(name){const z=Zain(name);const lv=G.inv[name]?.level||0;return Math.floor(z.baseDmg*60*Math.pow(3,lv));}
function prestigeReq(){return Math.floor(PRESTIGE_BASE*Math.pow(PRESTIGE_SCALE,G.prestige.count));}
function scalesForRun(){return Math.max(1,Math.floor(G.prestige.runCoins/COINS_PER_SCALE));}
function canPrestige(){return G.prestige.runCoins>=prestigeReq();}

function fmt(n){
  if(n>=1e15)return(n/1e15).toFixed(2)+'Qa';
  if(n>=1e12)return(n/1e12).toFixed(2)+'T';
  if(n>=1e9) return(n/1e9).toFixed(2)+'B';
  if(n>=1e6) return(n/1e6).toFixed(2)+'M';
  if(n>=1e3) return(n/1e3).toFixed(1)+'k';
  return String(Math.floor(n));
}

function wRand(ws){
  const t=ws.reduce((a,b)=>a+b,0); if(!t)return 0;
  let r=Math.random()*t;
  for(let i=0;i<ws.length;i++){r-=ws[i];if(r<=0)return i;}
  return ws.length-1;
}

const $=id=>document.getElementById(id);

// ════════════════════════════════════════════
// STATE
// ════════════════════════════════════════════
let G={
  coins:0,
  egg:null,      // {idx,hp,maxHp,cracked,shownCrack,isBoss?,bossTimer?}
  eq:null,
  inv:{},
  up:{clickPower:0,attackPower:0,attackSpeed:0,moneyMult:0,eggLuck:0},
  features:{quickLoot:false},
  prestige:{count:0,scales:0,runCoins:0},
  boss:{counter:0},
  stats:{hatched:0,earned:0,clicks:0},
};

// ════════════════════════════════════════════
// ATTACK LOOP
// ════════════════════════════════════════════
let atkTid=null;

function runAtk(){
  if(atkTid)clearTimeout(atkTid);
  (function tick(){
    if(G.eq&&G.egg){
      const d=zDmg(G.eq);
      const img=$('zain-img');
      img.classList.remove('lunging');
      void img.offsetWidth;
      img.classList.add('lunging');
      setTimeout(()=>{ if(G.egg) dealDmg(d,false); },195);
    }
    atkTid=setTimeout(tick,aInt(G.up.attackSpeed));
  })();
}

// ════════════════════════════════════════════
// COMBO SYSTEM
// ════════════════════════════════════════════
let combo=1.0, comboDecayTid=null;

function startComboDecay(){
  if(comboDecayTid)return;
  comboDecayTid=setInterval(()=>{
    if(combo<=1.0){combo=1.0;clearInterval(comboDecayTid);comboDecayTid=null;rComboBar();return;}
    combo=Math.max(1.0,combo-COMBO_DECAY);
    rComboBar();
  },1000);
}

function addCombo(){
  combo=Math.min(COMBO_MAX,combo+COMBO_GAIN);
  startComboDecay();
  rComboBar();
}

function rComboBar(){
  const wrap=$('combo-wrap');
  if(combo<=1.0){wrap.classList.remove('active');return;}
  wrap.classList.add('active');
  $('combo-label').textContent='×'+combo.toFixed(1)+' COMBO';
  $('combo-bar-fill').style.width=((combo-1)/(COMBO_MAX-1)*100)+'%';
}
let bossTid=null;
function startBossTimer(){
  stopBossTimer();
  bossTid=setInterval(()=>{
    if(!G.egg||!G.egg.isBoss){stopBossTimer();return;}
    G.egg.bossTimer=Math.max(0,G.egg.bossTimer-1);
    rBossTimer();
    if(G.egg.bossTimer<=0){stopBossTimer();bossEscape();}
  },1000);
}
function stopBossTimer(){if(bossTid){clearInterval(bossTid);bossTid=null;}}

function bossEscape(){
  G.egg=null;
  $('crack-txt').classList.remove('show');
  $('boss-timer-wrap').style.display='none';
  $('egg-img').classList.remove('boss-pulse');
  $('boss-esc-ov').classList.add('show');
  setTimeout(()=>{ $('boss-esc-ov').classList.remove('show'); setTimeout(spawnEgg,160); },2200);
}

// ════════════════════════════════════════════
// GAME LOGIC
// ════════════════════════════════════════════
function spawnEgg(){
  if(G.boss.counter>=BOSS_EVERY){ G.boss.counter=0; spawnBossEgg(); return; }
  G.boss.counter++;
  const lk=Math.min(G.up.eggLuck,20);
  const ei=wRand(LUCK[lk]);
  const e=EGGS[ei];
  // Corruption: 15% chance when eggLuck >= 10
  const corrupted=lk>=10&&Math.random()<CORRUPT_CHANCE;
  const hp=corrupted?e.hp*CORRUPT_HP_MULT:e.hp;
  G.egg={idx:ei,hp,maxHp:hp,cracked:false,shownCrack:false,isBoss:false,corrupted};
  $('boss-timer-wrap').style.display='none';
  $('egg-img').classList.remove('boss-pulse');
  rBossCounter(); rEgg();
}

function spawnBossEgg(){
  const lk=Math.min(G.up.eggLuck,20);
  const ei=Math.min(wRand(LUCK[lk])+1,EGGS.length-1);
  const e=EGGS[ei];
  const bHp=e.hp*BOSS_HP_MULT;
  G.egg={idx:ei,hp:bHp,maxHp:bHp,cracked:false,shownCrack:false,isBoss:true,corrupted:false,bossTimer:BOSS_TIMER_SECS};
  $('boss-timer-wrap').style.display='block';
  rBossTimer(); startBossTimer(); rBossCounter(); rEgg();
}

function onEggClick(ev){
  if(!G.egg)return;
  G.stats.clicks++;
  addCombo();
  const d=Math.floor(cDmg(G.up.clickPower)*combo);
  floatDmg(d,true,ev); shakeEgg(); dealDmg(d,true);
}

function dealDmg(amt,isClick){
  if(!G.egg)return;
  G.egg.hp=Math.max(0,G.egg.hp-amt);
  if(!G.egg.shownCrack&&G.egg.hp<=G.egg.maxHp/2){
    G.egg.cracked=true; G.egg.shownCrack=true;
    $('egg-img').src=EGGS[G.egg.idx].ci;
    showCrackFx();
  }
  rHp();
  if(G.egg.hp<=0)destroyEgg();
}

function showCrackFx(){
  const el=$('crack-txt');
  el.classList.remove('show'); void el.offsetWidth; el.classList.add('show');
  setTimeout(()=>el.classList.remove('show'),2600);
}

function shakeEgg(){
  const img=$('egg-img');
  img.classList.remove('shaking'); void img.offsetWidth; img.classList.add('shaking');
  img.addEventListener('animationend',()=>img.classList.remove('shaking'),{once:true});
}

function destroyEgg(){
  const wasBoss=G.egg.isBoss;
  const wasCorrupt=G.egg.corrupted;
  // Drop table: boss→+1 tier, corrupted→+1 tier, both→+2
  const dropIdx=Math.min(G.egg.idx+(wasBoss?1:0)+(wasCorrupt?1:0),EGGS.length-1);
  const e=EGGS[G.egg.idx];
  const base=(e.cMin+Math.random()*(e.cMax-e.cMin))*mMlt(G.up.moneyMult)*scalesMult();
  const coins=Math.floor(base*(wasBoss?BOSS_COIN_MULT:wasCorrupt?2:1));
  G.coins+=coins; G.stats.earned+=coins; G.prestige.runCoins+=coins;

  const zi=wRand(DROPS[dropIdx]);
  const z=ZAINS[zi];
  if(!G.inv[z.name])G.inv[z.name]={count:0,level:0,fusions:0};
  G.inv[z.name].count++;
  G.stats.hatched++;

  if(wasBoss){ stopBossTimer(); $('boss-timer-wrap').style.display='none'; $('egg-img').classList.remove('boss-pulse'); }
  G.egg=null;
  $('crack-txt').classList.remove('show');
  rCoins(); rInv(); rStats(); rPrestige(); rBossCounter();

  if(G.features.quickLoot){
    showQuickToast(z,coins,wasBoss,wasCorrupt);
    setTimeout(spawnEgg,160);
  } else {
    showHatch(z,coins,wasBoss,wasCorrupt);
    setTimeout(()=>{ hideHatch(); setTimeout(spawnEgg,160); },2400);
  }
}

function showHatch(z,coins,isBoss,isCorrupt){
  $('hatch-boss-badge').style.display=isBoss?'block':'none';
  $('hatch-corrupt-badge').style.display=isCorrupt?'block':'none';
  $('hatch-img').src=z.img;
  $('hatch-name').textContent=z.name; $('hatch-name').style.color=z.color;
  $('hatch-rar').textContent='★ '+z.rar; $('hatch-rar').style.color=z.color;
  $('hatch-coin').textContent='+💰 '+fmt(coins)+(isBoss?' (Boss Bonus!)':isCorrupt?' (Corruption Bonus!)':' coins!');
  $('hatch-ov').classList.add('show');
}
function hideHatch(){$('hatch-ov').classList.remove('show');}

let qlToastTid=null;
function showQuickToast(z,coins,isBoss,isCorrupt){
  $('ql-toast-img').src=z.img;
  const prefix=isBoss?'👑 ':isCorrupt?'🌑 ':'';
  $('ql-toast-name').textContent=prefix+z.name;
  $('ql-toast-name').style.color=isBoss?'#fb923c':isCorrupt?'#fb923c':z.color;
  $('ql-toast-rar').textContent='★ '+z.rar; $('ql-toast-rar').style.color=z.color;
  $('ql-toast-coin').textContent='+💰 '+fmt(coins)+(isBoss?' 🔥':isCorrupt?' 🌑':'');
  const t=$('ql-toast');
  t.classList.remove('show'); void t.offsetWidth; t.classList.add('show');
  if(qlToastTid)clearTimeout(qlToastTid);
  qlToastTid=setTimeout(()=>t.classList.remove('show'),1800);
}

function fuseZain(name,e){
  e.stopPropagation();
  const inv=G.inv[name]; if(!inv||inv.count<3)return;
  inv.count-=3;
  inv.fusions=(inv.fusions||0)+1;
  rInv(); if(G.eq===name)rEq();
  flash(`✦ ${name} fused! ×${Math.pow(2,inv.fusions).toFixed(0)} dmg bonus`);
}

const QUICK_LOOT_COST=2500;
function buyQuickLoot(){
  if(G.features.quickLoot)return;
  if(G.coins<QUICK_LOOT_COST){flashCoins();return;}
  G.coins-=QUICK_LOOT_COST; G.features.quickLoot=true;
  rCoins(); rFeatures();
}

function doPrestige(){
  if(!canPrestige())return;
  const earned=scalesForRun();
  G.prestige.scales+=earned; G.prestige.count++; G.prestige.runCoins=0;
  G.coins=0; G.inv={}; G.eq=null;
  G.up={clickPower:0,attackPower:0,attackSpeed:0,moneyMult:0,eggLuck:0};
  G.boss={counter:0}; G.egg=null;
  stopBossTimer();
  $('boss-timer-wrap').style.display='none';
  $('egg-img').classList.remove('boss-pulse');
  hideHatch(); $('crack-txt').classList.remove('show');
  const pf=$('pres-flash'); pf.classList.remove('go'); void pf.offsetWidth; pf.classList.add('go');
  flash(`⚖ Prestige ${G.prestige.count}! +${earned} Ancient Scales!`);
  fullRender(); runAtk(); spawnEgg();
}

function floatDmg(amt,isClick,ev){
  const c=$('center'); const cr=c.getBoundingClientRect();
  const el=document.createElement('div'); el.className='dflt';
  el.textContent=(isClick?'':'⚔ ')+'-'+fmt(amt);
  el.style.fontSize=isClick?'22px':'14px';
  el.style.color=isClick?'#f5c518':'#3ddc84';
  let x,y;
  if(isClick&&ev){x=ev.clientX-cr.left;y=ev.clientY-cr.top;}
  else{
    const er=$('egg-img').getBoundingClientRect();
    x=(er.left+er.right)/2-cr.left+(Math.random()-.5)*55;
    y=er.top-cr.top+35;
  }
  el.style.left=x+'px'; el.style.top=y+'px';
  c.appendChild(el);
  el.addEventListener('animationend',()=>el.remove());
}

function equipZain(name){ G.eq=name; rEq(); rInv(); }
function unequipZain(){ G.eq=null; rEq(); rInv(); }

function upgZain(name,e){
  e.stopPropagation();
  if(!G.inv[name])return;
  const c=zuCost(name);
  if(G.coins<c){flashCoins();return;}
  G.coins-=c; G.inv[name].level++;
  rCoins(); rInv(); if(G.eq===name)rEq();
}

function buyUpg(id){
  const def=UDEFS.find(d=>d.id===id);
  const lv=G.up[id];
  if(def.max!==Infinity&&lv>=def.max)return;
  const c=uCost(id);
  if(G.coins<c){flashCoins();return;}
  G.coins-=c; G.up[id]++;
  if(id==='attackSpeed')runAtk();
  rCoins(); rUpg(); rInv(); if(G.eq)rEq();
}

function flashCoins(){
  const e=$('coins-el'); e.style.color='#ff6b6b';
  setTimeout(()=>e.style.color='',350);
}

// ════════════════════════════════════════════
// RENDER
// ════════════════════════════════════════════
function rEgg(){
  if(!G.egg)return;
  const e=EGGS[G.egg.idx];
  const b=$('egg-badge');
  const img=$('egg-img');
  if(G.egg.isBoss){
    b.textContent='👑 BOSS — '+e.name+' Egg';
    b.className='egg-badge-boss'; b.style.color=''; b.style.borderColor=''; b.style.textShadow='';
    img.classList.remove('egg-img-corrupt'); img.classList.add('boss-pulse');
    img.style.filter=`drop-shadow(0 0 18px ${e.glow}) drop-shadow(0 0 35px #ef444466)`;
  } else if(G.egg.corrupted){
    b.textContent='🌑 CORRUPTED — '+e.name+' Egg';
    b.className='egg-badge-corrupt'; b.style.color=''; b.style.borderColor=''; b.style.textShadow='';
    img.classList.remove('boss-pulse'); img.classList.add('egg-img-corrupt'); img.style.filter='';
  } else {
    b.textContent=e.name+' Egg'; b.className='';
    b.style.color=e.color; b.style.borderColor=e.color; b.style.textShadow=`0 0 12px ${e.glow}`;
    img.classList.remove('boss-pulse','egg-img-corrupt');
    img.style.filter=`drop-shadow(0 0 22px ${e.glow})`;
  }
  img.src=G.egg.cracked?e.ci:e.ni;
  rHp();
}

function rHp(){
  if(!G.egg)return;
  const p=G.egg.hp/G.egg.maxHp;
  $('hp-fill').style.width=(p*100)+'%';
  $('hp-fill').style.background=
    G.egg.isBoss?'linear-gradient(90deg,#7f1d1d,#ef4444)':
    G.egg.corrupted?'linear-gradient(90deg,#78350f,#fb923c)':
    p>.5?'linear-gradient(90deg,#16a34a,#4ade80)':
    p>.25?'linear-gradient(90deg,#dc2626,#f87171)':
    'linear-gradient(90deg,#7f1d1d,#dc2626)';
  const suffix=G.egg.isBoss?' ⚠ BOSS':G.egg.corrupted?' 🌑 CORRUPTED':'';
  $('hp-txt').textContent=fmt(Math.ceil(G.egg.hp))+' / '+fmt(G.egg.maxHp)+suffix;
}

function rBossTimer(){
  if(!G.egg||!G.egg.isBoss)return;
  const t=G.egg.bossTimer;
  const pct=t/BOSS_TIMER_SECS;
  $('boss-timer-fill').style.width=(pct*100)+'%';
  $('boss-timer-fill').style.background=
    pct>.5?'linear-gradient(90deg,#ef4444,#fb923c)':
    pct>.25?'linear-gradient(90deg,#dc2626,#ef4444)':
    'linear-gradient(90deg,#7f1d1d,#dc2626)';
  $('boss-timer-txt').textContent=`⏱ ${t}s remaining — crack it before it escapes!`;
}

function rBossCounter(){
  const el=$('boss-counter');
  if(G.egg&&G.egg.isBoss){
    el.textContent=''; el.className=''; return;
  }
  const left=BOSS_EVERY-G.boss.counter;
  el.textContent=left<=3?`👑 BOSS INCOMING in ${left} egg${left===1?'':'s'}!`:`👑 Boss in: ${left} eggs`;
  el.className=left<=3?'warn':'';
}

function rEq(){
  const img=$('zain-img'),lbl=$('zain-lbl'),dps=$('zain-dps'),btn=$('unequip-btn');
  if(G.eq&&G.inv[G.eq]){
    const z=Zain(G.eq); const inv=G.inv[G.eq]; const fusions=inv.fusions||0;
    img.src=z.img; img.style.display='block';
    img.style.filter=fusions>0?`drop-shadow(0 0 14px #60a5facc)`:`drop-shadow(0 0 12px ${z.color}aa)`;
    lbl.textContent=G.eq+(fusions>0?` ✦×${Math.pow(2,fusions).toFixed(0)}`:'');
    lbl.style.display='block'; lbl.style.color=fusions>0?'#93c5fd':z.color;
    const d=zDmg(G.eq); const spd=1000/aInt(G.up.attackSpeed);
    dps.textContent=`${fmt(d)} dmg × ${spd.toFixed(2)}/s = ${fmt(Math.floor(d*spd))} DPS`;
    dps.style.display='block'; btn.style.display='block';
  } else {
    G.eq=null;
    img.style.display='none'; lbl.style.display='none';
    dps.style.display='none'; btn.style.display='none';
  }
}

function rInv(){
  const list=$('inv-list');
  const names=Object.keys(G.inv)
    .filter(n=>G.inv[n].count>0)
    .sort((a,b)=>ZAINS.indexOf(Zain(b))-ZAINS.indexOf(Zain(a)));
  if(!names.length){
    list.innerHTML=`<div class="iempty">No Zainasauruses yet!<br><br>🥚 Click the egg<br>to start cracking!</div>`;
    return;
  }
  list.innerHTML=names.map(name=>{
    const inv=G.inv[name],z=Zain(name),d=zDmg(name);
    const uc=zuCost(name),aff=G.coins>=uc,eq=G.eq===name;
    const fusions=inv.fusions||0; const canFuse=inv.count>=3;
    const sn=name.replace(/'/g,"\\'");
    return `<div class="icard${eq?' eq':''}" onclick="equipZain('${sn}')">
      <img class="idimg${fusions>0?' fusion-glow':''}" src="${z.img}" alt="${name}">
      <div class="iinfo">
        <div class="iname" style="color:${fusions>0?'#93c5fd':z.color}">${name}${fusions>0?` ✦×${Math.pow(2,fusions).toFixed(0)}`:''}</div>
        ${eq?'<div class="ieqb">⚔ EQUIPPED</div>':''}
        ${fusions>0?`<div class="fusion-badge">✦ ${fusions} Fusion${fusions>1?'s':''}</div>`:''}
        <div class="imeta">Lv.${inv.level} · ${z.rar}</div>
        <div class="idmg">⚔ ${fmt(d)} dmg/hit</div>
        <div style="display:flex;gap:4px;flex-wrap:wrap;margin-top:3px;">
          <button class="iubtn${aff?'':' dim'}" onclick="upgZain('${sn}',event)">Upgrade 💰${fmt(uc)}</button>
          ${canFuse?`<button class="fuse-btn" onclick="fuseZain('${sn}',event)">✦ Fuse (3×)</button>`:''}
        </div>
      </div>
      <div class="icnt">×${inv.count}</div>
    </div>`;
  }).join('');
}

function rUpg(){
  $('upg-list').innerHTML=UDEFS.map(def=>{
    const lv=G.up[def.id];
    const maxed=def.max!==Infinity&&lv>=def.max;
    const c=maxed?0:uCost(def.id);
    const aff=G.coins>=c;
    return `<div class="ucard${maxed?' umaxed':''}" onclick="${maxed?'':("buyUpg('"+def.id+"')")}">
      <div class="urow">
        <div class="uname">${def.name}</div>
        <div class="ulvl">Lv.${lv}${maxed?' ★MAX':''}</div>
      </div>
      <div class="udesc">${def.desc(lv)}</div>
      ${maxed
        ?'<div class="umxtxt">✨ MAXED OUT!</div>'
        :`<div class="ucost${aff?'':' dim'}">💰 ${fmt(c)}</div>`}
    </div>`;
  }).join('');
}

function rPrestige(){
  const req=prestigeReq();
  const run=G.prestige.runCoins;
  const pct=Math.min(1,run/req);
  const ready=canPrestige();
  const earned=scalesForRun();
  const mult=scalesMult();

  $('pres-count').textContent=G.prestige.count;
  $('pres-scales').textContent=G.prestige.scales;
  $('pres-mult').textContent='×'+mult.toFixed(2)+' (all dmg & coins)';
  $('scales-el').textContent=G.prestige.scales;
  $('scales-mult-el').textContent=mult>1?'×'+mult.toFixed(2):'';
  $('pres-prog').style.width=(pct*100)+'%';
  $('pres-prog-txt').textContent=ready
    ?`Ready! Will earn +${earned} Scales`
    :`${fmt(run)} / ${fmt(req)} coins this run`;
  const btn=$('pres-btn');
  btn.disabled=!ready;
  $('pres-box').className=ready?'ready':'';
  $('pres-warn').style.display=ready?'block':'none';
}

function rFeatures(){
  const owned=G.features.quickLoot;
  const aff=G.coins>=QUICK_LOOT_COST;
  $('feat-list').innerHTML=`
    <div class="feat-card${owned?' feat-owned':''}" onclick="${owned?'':'buyQuickLoot()'}">
      <div class="feat-row">
        <div class="feat-name">⚡ Quick Loot</div>
        ${owned?'<div class="feat-badge-owned">✓ OWNED</div>':''}
      </div>
      <div class="feat-desc">Skip the hatch screen — small non-blocking toast instead.</div>
      ${owned
        ?'<div class="feat-desc" style="color:#3ddc84;margin:0">Active!</div>'
        :`<div class="feat-cost${aff?'':' dim'}">💰 ${fmt(QUICK_LOOT_COST)}</div>`}
    </div>`;
}

function rCoins(){
  $('coins-el').textContent=fmt(G.coins);
  rUpg(); rFeatures(); rPrestige();
}

function rStats(){
  $('s-hatched').textContent=fmt(G.stats.hatched);
  $('s-clicks').textContent=fmt(G.stats.clicks);
  $('s-earned').textContent=fmt(G.stats.earned);
}

function fullRender(){
  rCoins(); rUpg(); rFeatures(); rPrestige(); rInv(); rEq(); rStats(); rBossCounter();
}

// ════════════════════════════════════════════
// SAVE / LOAD / EXPORT / IMPORT / RESET
// ════════════════════════════════════════════
const SK='crackAZain_v2';

function saveGame(){
  try{localStorage.setItem(SK,JSON.stringify(G));flash('✅ Saved!');}
  catch(e){flash('❌ Save failed');}
}
function loadGame(){
  try{
    const d=localStorage.getItem(SK);
    if(!d){flash('❌ No save found');return;}
    applyState(JSON.parse(d)); flash('✅ Loaded!');
  }catch(e){flash('❌ Load error');}
}
function exportGame(){
  const b=new Blob([JSON.stringify(G,null,2)],{type:'application/json'});
  const u=URL.createObjectURL(b);
  const a=document.createElement('a');
  a.href=u; a.download=`crack-a-zain-save-${Date.now()}.json`; a.click();
  URL.revokeObjectURL(u); flash('✅ Exported!');
}
function importGame(ev){
  const f=ev.target.files[0]; if(!f)return;
  const r=new FileReader();
  r.onload=e=>{
    try{applyState(JSON.parse(e.target.result));flash('✅ Imported!');}
    catch(err){flash('❌ Invalid file');}
  };
  r.readAsText(f); ev.target.value='';
}
function resetGame(){
  if(!confirm('Reset ALL progress including Prestiges? This cannot be undone!'))return;
  localStorage.removeItem(SK);
  stopBossTimer();
  G={coins:0,egg:null,eq:null,inv:{},
     up:{clickPower:0,attackPower:0,attackSpeed:0,moneyMult:0,eggLuck:0},
     features:{quickLoot:false},
     prestige:{count:0,scales:0,runCoins:0},
     boss:{counter:0},
     stats:{hatched:0,earned:0,clicks:0}};
  hideHatch(); $('crack-txt').classList.remove('show');
  $('boss-timer-wrap').style.display='none'; $('egg-img').classList.remove('boss-pulse');
  fullRender(); runAtk(); spawnEgg(); flash('🗑 Reset complete');
}

function applyState(st){
  stopBossTimer();
  G.coins=st.coins||0;
  G.inv=st.inv||{};
  G.up=Object.assign({clickPower:0,attackPower:0,attackSpeed:0,moneyMult:0,eggLuck:0},st.up||{});
  G.features=Object.assign({quickLoot:false},st.features||{});
  G.prestige=Object.assign({count:0,scales:0,runCoins:0},st.prestige||{});
  G.boss=Object.assign({counter:0},st.boss||{});
  G.stats=Object.assign({hatched:0,earned:0,clicks:0},st.stats||{});
  G.eq=st.eq||null; G.egg=null;
  hideHatch(); $('crack-txt').classList.remove('show');
  $('boss-timer-wrap').style.display='none'; $('egg-img').classList.remove('boss-pulse');
  fullRender(); runAtk(); spawnEgg();
}

let flashTid=null;
function flash(msg){
  const e=$('flash'); e.textContent=msg;
  if(flashTid)clearTimeout(flashTid);
  flashTid=setTimeout(()=>e.textContent='',2500);
}

// Autosave every 30s
setInterval(saveGame,30000);

// ════════════════════════════════════════════
// STARS
// ════════════════════════════════════════════
(function makeStars(){
  const s=$('stars');
  for(let i=0;i<55;i++){
    const el=document.createElement('div');
    el.className='star';
    const sz=Math.random()*2+1;
    el.style.cssText=`
      width:${sz}px;height:${sz}px;
      left:${Math.random()*100}%;top:${Math.random()*100}%;
      opacity:${Math.random()*.2+.03};
      --d:${(Math.random()*3+2).toFixed(1)}s;
      --delay:${(Math.random()*4).toFixed(1)}s;
    `;
    s.appendChild(el);
  }
})();

// ════════════════════════════════════════════
// INIT
// ════════════════════════════════════════════
try{
  const d=localStorage.getItem(SK);
  if(d){
    const st=JSON.parse(d);
    G.coins=st.coins||0;
    G.inv=st.inv||{};
    G.up=Object.assign({clickPower:0,attackPower:0,attackSpeed:0,moneyMult:0,eggLuck:0},st.up||{});
    G.features=Object.assign({quickLoot:false},st.features||{});
    G.prestige=Object.assign({count:0,scales:0,runCoins:0},st.prestige||{});
    G.boss=Object.assign({counter:0},st.boss||{});
    G.stats=Object.assign({hatched:0,earned:0,clicks:0},st.stats||{});
    G.eq=st.eq||null;
  }
}catch(e){}

fullRender();
spawnEgg();
runAtk();
</script>
</body>
</html>
